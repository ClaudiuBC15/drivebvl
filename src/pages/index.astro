---
import MainLayout from '../layouts/main.astro';

// Content for the hero slider
const slides = [
  {
    image: 'https://i.imgur.com/dxsvS4U.jpeg',
    title: 'Școala de Șoferi',
    highlight: 'START DRIVE BVL',
    desc: 'Performanță, Siguranță și Profesionalism în Inima Sucevei. Pregătim generații de șoferi responsabili.'
  },
  {
    image: 'https://i.imgur.com/miHAgHu.jpeg',
    title: 'Instructori Auto',
    highlight: 'De Top',
    desc: 'O echipă dedicată și răbdătoare, gata să îți ofere tot suportul de care ai nevoie pentru a promova.'
  },
  {
    image: 'https://i.imgur.com/SsZQl1w.jpeg',
    title: 'Toate Categoriile',
    highlight: 'B, B1, C, CE',
    desc: 'De la autoturisme până la camioane de mare tonaj, avem resursele și experiența necesară.'
  }
];

const reviews = [
  {
    name: "Alexandru Popa",
    initial: "A",
    time: "acum 2 luni",
    text: "Am avut o experiență excelentă cu școala de șoferi Start Drive BVL. Instructorii sunt calmi, profesioniști și te învață de la zero tot ce trebuie să știi pentru a lua permisul din prima. O recomand cu mare încredere!",
    stars: 5,
    bg: "bg-blue-500"
  },
  {
    name: "Maria Ionescu",
    initial: "M",
    time: "acum 3 luni",
    text: "Cea mai bună școală auto din Suceava! Mașinile sunt impecabile, iar programul de condus a fost mereu flexibil, perfect pentru programul meu. Am luat sala cu 26 și traseul fără emoții datorită pregătirii de top.",
    stars: 5,
    bg: "bg-rose-500"
  },
  {
    name: "Cristian D.",
    initial: "C",
    time: "acum 5 luni",
    text: "Profesionalism la superlativ. Instructorul meu a avut extrem de multă răbdare, mi-a explicat fiecare detaliu și a creat o atmosferă relaxată la volan, fără stres. Am recomandat deja Start Drive tuturor prietenilor mei.",
    stars: 5,
    bg: "bg-emerald-500"
  }
];

const googleReviewsUrl = "https://www.google.com/search?q=START+DRIVE+BVL+(Scoala+de+Soferi)+Recenzii";

const galleryPreview = [
  "https://i.imgur.com/a7H0dcY.jpeg",
  "https://i.imgur.com/y7rAASu.jpeg",
  "https://i.imgur.com/TNY8kty.jpeg",
  "https://i.imgur.com/GZrbulS.jpeg",
  "https://i.imgur.com/lL14tcK.jpeg",
  "https://i.imgur.com/5FAerI9.jpeg",
];

const faqs = [
  {
    q: "Cât durează cursurile pentru școala de șoferi (Categoria B)?",
    a: "Cursurile pentru obținerea permisului auto de categoria B la școala noastră din Suceava durează minim 4 săptămâni. Acestea includ 24 de ore de pregătire teoretică (legislație rutieră, prim ajutor, mecanică) și 30 de ore de conducere practică alături de instructori autorizați."
  },
  {
    q: "Se poate achita școlarizarea auto în rate?",
    a: "Da, la Start Drive BVL oferim flexibilitate maximă cursanților noștri. Poți achita școlarizarea în rate egale, fără dobândă, pe parcursul celor 4 săptămâni de pregătire, prima rată achitându-se la înscriere."
  },
  {
    q: "Ce documente conține dosarul de înscriere la examenul auto?",
    a: "Pentru a te înscrie, ai nevoie de: Cartea de identitate (în original și copie), aviz psihologic eliberat de un cabinet autorizat, fișa medicală auto, cazier judiciar cu mențiunea 'examen auto' și chitanța pentru plata taxei de permis."
  },
  {
    q: "Pot alege mașina și instructorul auto pe care voi face pregătirea?",
    a: "Absolut! Dispuneam de o flotă auto modernă și diversificată (cutie manuală și automată) și o echipă de instructori cu o rată mare de promovabilitate. Ne adaptăm preferințelor tale pentru a-ți asigura cel mai ridicat nivel de confort la volan."
  },
  {
    q: "Ce se întâmplă dacă pic examenul practic (traseul)?",
    a: "Dacă ești respins la proba practică, dosarul rămâne valabil timp de 1 an de la promovarea sălii. Va trebui să efectuezi obligatoriu un pachet suplimentar minim de ore de condus (3 ședințe) înainte de a te putea reprograma pentru un nou examen auto."
  },
  {
    q: "Sala de legislație se susține înainte de a începe orele de condus?",
    a: "Da, legea impune parcurgerea și finalizarea cursurilor de pregătire teoretică (legislație rutieră) înainte de a începe pregătirea practică (orele de condus) pe drumurile publice."
  }
];

const blogPosts = [
  {
    title: "Cum să scapi de emoții la examenul auto",
    date: "15 Mai 2026",
    excerpt: "Descoperă cele mai bune 5 tehnici pentru a-ți controla emoțiile în ziua examenului cu polițistul.",
    image: "https://i.imgur.com/TNY8kty.jpeg"
  },
  {
    title: "Modificări legislative codul rutier 2026",
    date: "02 Mai 2026",
    excerpt: "Află ce schimbări importante au apărut în Codul Rutier anul acesta și cum te afectează ca viitor șofer.",
    image: "https://i.imgur.com/SsZQl1w.jpeg"
  },
  {
    title: "Cum alegi categoria potrivită de permis?",
    date: "20 Aprilie 2026",
    excerpt: "Ghid complet despre diferențele dintre categoriile B, BE, C și CE și oportunitățile pe care ți le oferă.",
    image: "https://i.imgur.com/dxsvS4U.jpeg"
  }
];
---

<MainLayout>
  <!-- Hero Slider -->
  <section class="relative w-full h-[600px] lg:h-[750px] overflow-hidden bg-slate-900 group">
    <div id="slider-container" class="relative w-full h-full">
      {slides.map((slide, i) => (
        <div class="slide absolute inset-0 w-full h-full opacity-0 transition-opacity duration-1000 ease-in-out" data-index={i}>
          <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-black/20 z-10"></div>
          <img src={slide.image} alt={slide.title} class="absolute inset-0 w-full h-full object-cover scale-100 slide-img transition-transform duration-[8000ms] ease-out" />
          
          <div class="relative z-20 h-full flex items-center px-6 md:px-16 max-w-7xl mx-auto">
            <div class="max-w-2xl slide-content translate-y-12 opacity-0 transition-all duration-1000 ease-out delay-300">
              <!-- Ovasal inspired badge -->
              <div class="inline-flex items-center gap-2 bg-rose-600/20 border border-rose-500/30 text-white px-4 py-1.5 rounded-full mb-6 backdrop-blur text-sm font-semibold">
                <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
                Garanția calității. Sute de Suceveni au REUȘIT!
              </div>

              <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 drop-shadow-xl tracking-tight leading-[1.1]">
                {slide.title} <br/>
                <span class="text-[#cc0000]">{slide.highlight}</span>
              </h2>
              <p class="text-lg md:text-xl text-slate-200 mb-10 font-light drop-shadow max-w-xl">
                {slide.desc}
              </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a href="/inscrieri" class="bg-[#cc0000] hover:bg-[#a30000] text-white font-bold py-4 px-8 rounded shadow-lg shadow-rose-600/30 transition-transform hover:-translate-y-1 text-center uppercase tracking-wider text-sm">
                  Înscrie-te Online
                </a>
                <a href="/categorii" class="bg-white/10 hover:bg-white/20 backdrop-blur border border-white/30 text-white font-bold py-4 px-8 rounded transition-all hover:-translate-y-1 text-center uppercase tracking-wider text-sm">
                  Vezi Categoriile
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Ovasal Trust Strip Bottom -->
    <div class="absolute bottom-0 left-0 right-0 z-30 bg-black/40 backdrop-blur-md border-t border-white/10 hidden md:block">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-white">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-[#cc0000] rounded-full"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
          <span class="font-semibold tracking-widest text-sm uppercase">Plata în rate flexibile</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="p-2 bg-[#cc0000] rounded-full"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
          <span class="font-semibold tracking-widest text-sm uppercase">Instructori de TOP</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="p-2 bg-[#cc0000] rounded-full"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg></div>
          <span class="font-semibold tracking-widest text-sm uppercase">Garanția Calității</span>
        </div>
      </div>
    </div>

    <!-- Navigation Arrows -->
    <button id="prev-slide" class="absolute left-6 top-1/2 -translate-y-1/2 z-30 w-14 h-14 bg-white/10 hover:bg-white/30 backdrop-blur border border-white/20 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all hover:scale-110">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="next-slide" class="absolute right-6 top-1/2 -translate-y-1/2 z-30 w-14 h-14 bg-white/10 hover:bg-white/30 backdrop-blur border border-white/20 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all hover:scale-110">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
  </section>

  <!-- Tipuri de școlarizare -->
  <section class="py-24 bg-[#f8fafc] relative overflow-hidden">
    <!-- Decorativ -->
    <div class="absolute top-0 right-0 -mr-32 -mt-32 w-96 h-96 rounded-full bg-rose-100/50 blur-3xl z-0 pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="max-w-xl">
          <span class="text-sm font-bold text-[#cc0000] tracking-widest uppercase mb-2 block">START DRIVE BVL</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-8 leading-tight">Excelență în Educația Auto din Suceava</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Alegerea unei școli de șoferi este primul pas către independența ta. Cu <strong>Start Drive BVL</strong>, ai verde la condus. Oferim o abordare completă, combinând <span class="font-bold text-slate-800">sală de legislație modernizată</span>, instructori cu ani de experiență și o <span class="font-bold text-slate-800">flotă auto de ultimă generație</span>.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Misiunea noastră este să formăm conducători auto responsabili și siguri pe ei. De la pregătirea teoretică până la examenul practic cu poliția, te ghidăm pas cu pas. Procentajul nostru de promovabilitate se numără printre cele mai ridicate din județ datorită dedicării echipei noastre.
          </p>
          <ul class="space-y-4 mb-8">
             <li class="flex items-center gap-3"><svg class="w-5 h-5 text-[#cc0000]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span class="text-slate-700 font-medium">Program de condus flexibil adaptat ție</span></li>
             <li class="flex items-center gap-3"><svg class="w-5 h-5 text-[#cc0000]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span class="text-slate-700 font-medium">Plată în rate egale, fără absolut nicio dobândă</span></li>
             <li class="flex items-center gap-3"><svg class="w-5 h-5 text-[#cc0000]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span class="text-slate-700 font-medium">Suport complet pentru dosarul de examen DRPCIV</span></li>
          </ul>
        </div>

        <div class="grid sm:grid-cols-2 gap-8 relative lg:-mt-12">
          <!-- Glassmorphism Card 1 -->
          <div class="bg-white/80 backdrop-blur-md rounded-2xl shadow-2xl border border-white overflow-hidden hover:-translate-y-2 transition-all duration-300 h-full flex flex-col relative z-20 group">
            <div class="relative overflow-hidden h-56">
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent z-10 pointer-events-none"></div>
              <img src="https://i.imgur.com/dxsvS4U.jpeg" alt="Flota auto Categoria B" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <h3 class="absolute bottom-4 left-6 text-2xl font-bold text-white z-20">Categorii Auto</h3>
            </div>
            <div class="p-8 flex flex-col flex-grow items-center text-center">
              <p class="text-slate-600 font-light mb-8 text-sm flex-grow">
                Fie că dorești permisul pentru <strong>categoria B</strong>, ai nevoie de remorcă (<strong>BE</strong>) sau țintești cariera de șofer profesionist (<strong>C, CE</strong>), dispunem de vehicule moderne.
              </p>
              <a href="/categorii" class="w-full bg-slate-900 hover:bg-[#cc0000] text-white py-4 px-6 text-sm font-bold uppercase tracking-wider rounded transition-colors flex items-center justify-between group-hover:shadow-lg">
                Vezi Mașinile
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          
          <!-- Glassmorphism Card 2 -->
          <div class="bg-white/80 backdrop-blur-md rounded-2xl shadow-2xl border border-white overflow-hidden hover:-translate-y-2 transition-all duration-300 lg:mt-16 h-full flex flex-col relative z-10 group">
            <div class="relative overflow-hidden h-56">
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent z-10 pointer-events-none"></div>
              <img src="https://i.imgur.com/SsZQl1w.jpeg" alt="Sala de curs legislație auto" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <h3 class="absolute bottom-4 left-6 text-2xl font-bold text-white z-20">Pregătire Teoretică</h3>
            </div>
            <div class="p-8 flex flex-col flex-grow items-center text-center">
              <p class="text-slate-600 font-light mb-8 text-sm flex-grow">
                Punem accent pe o pregătire teoretică de excepție. Sala noastră este dotată cu tehnologie interactivă și simulatoare de examen auto.
              </p>
              <a href="/inscrieri" class="w-full bg-slate-900 hover:bg-[#cc0000] text-white py-4 px-6 text-sm font-bold uppercase tracking-wider rounded transition-colors flex items-center justify-between group-hover:shadow-lg">
                Înscrie-te
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cine suntem & De ce noi -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text -->
        <div>
          <span class="text-sm font-bold text-[#cc0000] tracking-widest uppercase mb-2 block">DESPRE NOI</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-6 leading-tight">De ce să alegi Start Drive BVL?</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Cu ani de experiență în domeniul educației rutiere, școala noastră de șoferi din Suceava se distinge prin profesionalism, răbdare și rezultate dovedite. 
          </p>
          <div class="space-y-6 mt-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-rose-50 text-[#cc0000] flex items-center justify-center shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-slate-800 mb-1">Rată Mare de Promovabilitate</h4>
                <p class="text-slate-600 font-light">Mândria noastră este numărul mare de cursanți care obțin permisul auto din prima încercare, datorită pregătirii riguroase și simulărilor de examen.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-rose-50 text-[#cc0000] flex items-center justify-center shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-slate-800 mb-1">Program Adaptabil</h4>
                <p class="text-slate-600 font-light">Înțelegem că ai un program încărcat. Oferim flexibilitate în programarea orelor de condus, încercând să ne pliem pe disponibilitatea ta.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-rose-50 text-[#cc0000] flex items-center justify-center shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-slate-800 mb-1">Plată în Rate (Fără Dobândă)</h4>
                <p class="text-slate-600 font-light">Costul școlii de șoferi nu trebuie să fie o povară. Oferim posibilitatea plății în rate egale pe toată durata cursurilor.</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Image Grid -->
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4 mt-8">
            <img src="https://i.imgur.com/dxsvS4U.jpeg" alt="Instructor Auto" class="w-full h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
            <img src="https://i.imgur.com/TNY8kty.jpeg" alt="Cursant fericit" class="w-full h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
          </div>
          <div class="space-y-4">
            <img src="https://i.imgur.com/SsZQl1w.jpeg" alt="Sala Legislatie" class="w-full h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
            <img src="https://i.imgur.com/y7rAASu.jpeg" alt="Masina Scoala" class="w-full h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Carusel Categorii (Ovasal Style) -->
  <section class="py-24 bg-[#111111] relative overflow-hidden">
    
    <!-- Decorații fundal (Linii punctate accent) -->
    <div class="absolute left-10 top-1/2 flex gap-2">
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
    </div>
    <div class="absolute right-10 bottom-24 flex gap-2">
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
      <div class="w-8 h-2 bg-[#cc0000] transform -skew-x-12"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 relative z-10">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white">Permis auto</h2>
      </div>

      <div class="flex justify-end gap-2 mb-4 relative z-10">
        <button id="cat-prev" class="w-10 h-10 border border-white/20 flex items-center justify-center text-white hover:bg-[#cc0000] hover:border-[#cc0000] transition-colors focus:outline-none">
