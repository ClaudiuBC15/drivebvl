  <!-- ==================== SCRIPTS ==================== -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // === Count-up Animation ===
      const countUpElements = document.querySelectorAll('.count-up');
      if (countUpElements.length > 0) {
        const countObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const target = parseInt(el.dataset.target);
              const suffix = el.dataset.suffix || '';

              if (reduceMotion) {
                el.textContent = target + suffix;
                countObserver.unobserve(el);
                return;
              }

              let current = 0;
              const duration = 1800;
              const step = target / (duration / 16);
              function animate() {
                current += step;
                if (current >= target) {
                  el.textContent = target + suffix;
                  return;
                }
                el.textContent = Math.floor(current) + suffix;
                requestAnimationFrame(animate);
              }
              animate();
              countObserver.unobserve(el);
            }
          });
        }, { threshold: 0.5 });
        countUpElements.forEach(el => countObserver.observe(el));
      }

      // === Parallax Hero (skipped under reduced motion) ===
      const heroParallax = document.getElementById('hero-parallax');
      if (heroParallax && !reduceMotion) {
        const parallaxObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              window.addEventListener('scroll', handleParallax, { passive: true });
            } else {
              window.removeEventListener('scroll', handleParallax);
            }
          });
        });
        parallaxObserver.observe(heroParallax);

        function handleParallax() {
          const scrollY = window.scrollY;
          heroParallax.style.transform = `translate3d(0, ${scrollY * 0.3}px, 0)`;
        }
      }

      // === Categories Carousel ===
      const categoriesScroll = document.getElementById('categories-scroll');
      const categoriesPrev = document.getElementById('categories-prev');
      const categoriesNext = document.getElementById('categories-next');
      if (categoriesScroll && categoriesPrev && categoriesNext) {
        categoriesNext.addEventListener('click', () => categoriesScroll.scrollBy({ left: 340, behavior: 'smooth' }));
        categoriesPrev.addEventListener('click', () => categoriesScroll.scrollBy({ left: -340, behavior: 'smooth' }));
      }

      // === Cars Carousel ===
      const carsScroll = document.getElementById('cars-scroll');
      const carsPrev = document.getElementById('cars-prev');
      const carsNext = document.getElementById('cars-next');
      if (carsScroll && carsPrev && carsNext) {
        carsNext.addEventListener('click', () => carsScroll.scrollBy({ left: 400, behavior: 'smooth' }));
        carsPrev.addEventListener('click', () => carsScroll.scrollBy({ left: -400, behavior: 'smooth' }));
      }
    });
  </script>
</MainLayout>
