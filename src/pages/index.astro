---
import MainLayout from '../layouts/main.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Testimonials3D from '../components/ui/3d-testimonials-demo';
import StatsCards from '../components/ui/StatsCards';
import { getDB, queryAll } from '../lib/db';

export const prerender = false;

const db = getDB(Astro.locals);

const fallbackInstructors = [
  {
    name: "Tofan Florin",
    role: "Instructor Auto & Profesor Legislație",
    categories: "B1, B, BE, C, CE, D, DE",
    experience: "15+",
    students: "280+",
    image: "/images/instructori/tofan-florin.png"
  },
  {
    name: "Bivol Sergiu",
    role: "Fondator & Instructor",
    categories: "B1, B, BE, C, CE, D, DE",
    experience: "12+",
    students: "250+",
    image: "/images/instructori/bivol-sergiu.jpeg"
  },
  {
    name: "Bejinariu Florin",
    role: "Instructor Auto & Profesor Legislație",
    categories: "B1, B, BE",
    experience: "10+",
    students: "300+",
    image: "/images/instructori/bejinariu-florin.png"
  },
  {
    name: "Radu Matei",
    role: "Instructor Practic",
    categories: "B, B1",
    experience: "6+",
    students: "150+",
    image: "/images/instructori/radu-matei.png"
  }
];

let instructors = [];
try {
  const dbInstructors = await queryAll<any>(db, 'SELECT * FROM instructors ORDER BY sort_order ASC');
  if (dbInstructors && dbInstructors.length > 0) {
    instructors = dbInstructors.map(inst => ({
      name: inst.name,
      role: inst.role,
      categories: inst.categories,
      experience: inst.experience,
      students: inst.students,
      image: inst.image_url
    }));
  } else {
    instructors = fallbackInstructors;
  }
} catch (err) {
  console.error('Error loading instructors on homepage:', err);
  instructors = fallbackInstructors;
}

const fallbackCategories = [
  { id: 'B1', name: 'Categoria B1', subtitle: 'Cvadricicluri — de la 16 ani', image: '/images/cat-b1.png' },
  { id: 'B',  name: 'Categoria B',  subtitle: 'Autoturisme — cel mai popular', image: '/images/cat-b.png' },
  { id: 'BE', name: 'Categoria BE', subtitle: 'Mașină + Remorcă', image: '/images/cat-be.png' },
  { id: 'C',  name: 'Categoria C',  subtitle: 'Camioane — peste 3.500 kg', image: '/images/cat-c.png' },
  { id: 'CE', name: 'Categoria CE', subtitle: 'TIR — ansamblu autotren', image: '/images/cat-ce.png' },
  { id: 'D',  name: 'Categoria D',  subtitle: 'Autobuze — transport persoane', image: '/images/cat-b.png' }
];

let categories = [];
try {
  const dbCategories = await queryAll<any>(db, 'SELECT * FROM categories ORDER BY sort_order ASC');
  if (dbCategories && dbCategories.length > 0) {
    categories = dbCategories.map(cat => ({
      id: cat.id,
      name: cat.name,
      subtitle: cat.hero_subtitle || cat.name,
      image: cat.image_url
    }));
  } else {
    categories = fallbackCategories;
  }
} catch (err) {
  console.error('Error loading categories on homepage:', err);
  categories = fallbackCategories;
}

const steps = [
  { n: '01', icon: '📞', title: 'Contactează-ne', desc: 'Sună-ne sau vino la sediu pentru a discuta opțiunile de școlarizare.' },
  { n: '02', icon: '📋', title: 'Acte necesare', desc: 'Pregătește documentele: CI, cazier, aviz medical și psihologic.' },
  { n: '03', icon: '👨‍🏫', title: 'Alege instructorul', desc: 'Îți prezentăm echipa și alegi instructorul potrivit stilului tău.' },
  { n: '04', icon: '🚗', title: 'Ore teorie + practică', desc: 'Parcurgi cursurile teoretice și orele de condus alături de instructor.' },
  { n: '05', icon: '🎉', title: 'Examen și permis', desc: 'Susții examenul cu încredere și primești permisul de conducere!' }
];

const fallbackCars = [
  { image: '/images/flota/dacia-logan.jpeg',         model: 'Dacia Logan',         tag: 'Manual' },
  { image: '/images/flota/dacia-sandero.jpeg',       model: 'Dacia Sandero',       tag: 'Manual' },
  { image: '/images/flota/dacia-logan-stepway.jpeg', model: 'Dacia Logan Stepway', tag: 'Manual' },
  { image: '/images/flota/man-tgl.jpeg',             model: 'MAN TGL (Camion)',    tag: 'Manual' },
  { image: '/images/flota/dacia-duster.jpeg',        model: 'Dacia Duster',        tag: 'Manual' },
];

let cars = [];
try {
  const dbCars = await queryAll<any>(db, 'SELECT * FROM cars ORDER BY sort_order ASC');
  if (dbCars && dbCars.length > 0) {
    cars = dbCars.map(c => ({
      image: c.image_url,
      model: c.model,
      tag: c.tag
    }));
  } else {
    cars = fallbackCars;
  }
} catch (err) {
  console.error('Error loading cars on homepage:', err);
  cars = fallbackCars;
}

const benefits = [
  { title: 'Program flexibil', desc: 'Ore de condus adaptate programului tău — inclusiv weekend.' },
  { title: 'Plată în rate', desc: 'Rate egale, fără dobândă, fără gaj.' },
  { title: 'Dosar DRPCIV', desc: 'Suport complet pentru întocmirea dosarului de examen.' },
  { title: '95% promovabilitate', desc: 'Majoritatea cursanților noștri reușesc din prima.' },
];

const googleReviewsUrl = "https://www.google.com/search?q=START+DRIVE+BVL+(Scoala+de+Soferi)+Recenzii";
---

<MainLayout
  title="Start Drive BVL | Școala de Șoferi Suceava — Categorii B, BE, C, CE"
  description="Școala de Șoferi Start Drive BVL din Suceava — instructori experimentați, flotă modernă, rată de promovabilitate 95%. Categorii B, B1, BE, C, CE. Înscrie-te acum!"
>

  <!-- ==================== HERO ==================== -->
  <section id="hero-section" class="relative w-full min-h-screen flex flex-col justify-between overflow-hidden bg-[#0a0a0b]">
    <!-- Parallax Background Image -->
    <div id="hero-parallax" class="absolute inset-0 w-full h-full">
      <img src="/images/hero_nou.jpg" alt="Absolvenți Start Drive BVL Suceava — Conducem în direcția corectă!" class="w-full h-full object-cover object-center" style="image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;" />
    </div>
    <!-- Overlay echilibrat — text lizibil, imagine parțial vizibilă -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0b]/82 via-[#0a0a0b]/55 to-[#0a0a0b]/70 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0b] via-[#0a0a0b]/25 to-transparent z-10"></div>

    <!-- Main Content Area -->
    <div class="relative z-20 container-wide pt-28 pb-10 md:pt-36 md:pb-16 flex-grow flex items-center w-full">
      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-md border border-white/15 text-white px-4 py-2 rounded-full mb-8 text-sm font-semibold reveal">
          <span class="w-2 h-2 rounded-full bg-[#cc0000] ping-dot"></span>
          Garanția calității — Peste 2000 de absolvenți au REUȘIT!
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.02] reveal" style="font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.035em">
          Școala de Șoferi<br/>
          <span class="text-[#cc0000]">Start Drive BVL</span>
        </h1>

        <p class="text-lg md:text-xl text-white/75 mb-10 max-w-xl leading-relaxed reveal" style="font-family:'Inter',sans-serif">
          Performanță, siguranță și profesionalism în inima Sucevei. Pregătim generații de șoferi responsabili.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 reveal">
          <Button href="/inscrieri" variant="primary" ripple>Înscrie-te Online</Button>
          <Button href="/categorii" variant="outline">Vezi Categoriile</Button>
        </div>

        <!-- Trust strip -->
        <div class="flex flex-wrap items-center gap-x-8 gap-y-4 mt-12 reveal">
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-white/70 text-sm font-medium">5.0 pe Google</span>
          </div>
          <div class="w-px h-5 bg-white/15 hidden sm:block"></div>
          <div class="text-white/70 text-sm"><span class="text-white font-semibold">2000+</span> absolvenți</div>
          <div class="w-px h-5 bg-white/15 hidden sm:block"></div>
          <div class="text-white/70 text-sm"><span class="text-white font-semibold">Flotă</span> modernă</div>
        </div>
      </div>
    </div>

    <!-- Integrated Stats Cards at the bottom of the Hero -->
    <div class="relative z-20 container-wide pb-8 md:pb-12 w-full reveal animate-fade-in">
      <StatsCards client:load />
    </div>
  </section>

  <!-- ==================== DESPRE NOI ==================== -->
  <section class="py-24 sm:py-28 bg-white overflow-hidden">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">
        <!-- Text -->
        <div class="reveal">
          <span class="eyebrow">Despre Noi</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-[#0a0a0b] mb-6 leading-[1.08] mt-4" style="font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.03em">
            De ce să alegi<br/>Start Drive BVL?
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Cu ani de experiență în domeniul educației rutiere, școala noastră din Suceava se distinge prin profesionalism, răbdare și rezultate dovedite. Combinăm <strong class="text-[#0a0a0b]">sală de legislație modernizată</strong>, instructori dedicați și o <strong class="text-[#0a0a0b]">flotă auto de ultimă generație</strong>.
          </p>

          <div class="grid sm:grid-cols-2 gap-x-6 gap-y-4 mb-9">
            {benefits.map(b => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <p class="font-bold text-[#0a0a0b] text-[15px]">{b.title}</p>
                  <p class="text-slate-500 text-sm leading-snug">{b.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <Button href="/contact" variant="ghost" ripple>
            Contactează-ne
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </Button>
        </div>

        <!-- Stacked Images with overlap -->
        <div class="relative reveal">
          <div class="relative">
            <img src="/images/hero_nou.jpg" alt="Start Drive BVL" class="w-full h-[360px] object-cover rounded-2xl shadow-2xl" loading="lazy" />
            <img src="/images/imagine.jpeg" alt="Mașina de școală Start Drive BVL" class="w-[64%] h-[230px] object-cover rounded-2xl shadow-2xl absolute -bottom-12 -right-4 lg:right-[-30px] border-4 border-white" loading="lazy" />
            <!-- Stats badge on overlap -->
            <div class="absolute -bottom-6 left-6 bg-[#cc0000] text-white px-6 py-3 rounded-xl shadow-xl">
              <span class="text-2xl font-extrabold" style="font-family:'Plus Jakarta Sans',sans-serif">15+</span>
              <span class="text-xs block uppercase tracking-[0.12em] opacity-90">Ani Experiență</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CATEGORII ==================== -->
  <section class="py-24 sm:py-28 bg-[#f6f6f7]">
    <div class="container-wide">
      <div class="flex flex-col sm:flex-row justify-between items-end gap-6 mb-12 reveal">
        <div>
          <span class="eyebrow">Ce Poți Conduce</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-[#0a0a0b] mt-4" style="font-family:'Plus Jakarta Sans',sans-serif; letter-spacing:-0.03em">Categorii Permis Auto</h2>
        </div>
        <div class="flex gap-2">
          <button id="categories-prev" class="w-12 h-12 rounded-full border-2 border-[#0a0a0b] flex items-center justify-center hover:bg-[#cc0000] hover:border-[#cc0000] hover:text-white transition-all cursor-pointer" aria-label="Anterior">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="categories-next" class="w-12 h-12 rounded-full border-2 border-[#0a0a0b] flex items-center justify-center hover:bg-[#cc0000] hover:border-[#cc0000] hover:text-white transition-all cursor-pointer" aria-label="Următorul">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <div id="categories-scroll" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar scroll-smooth pb-4">
        {categories.map((cat, i) => (
          <a href={`/categoria/${cat.id.toLowerCase()}`} class="min-w-[280px] md:min-w-[320px] group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 reveal bg-white shrink-0 snap-center" style={`transition-delay:${i * 90}ms`}>
            <div class="relative h-48 sm:h-72 overflow-hidden bg-slate-50">
              <img src={cat.image} alt={cat.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <!-- gradient replaces harsh red overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0b]/85 via-[#0a0a0b]/10 to-transparent"></div>
              <div class="absolute inset-0 bg-[#cc0000]/0 group-hover:bg-[#cc0000]/30 transition-all duration-500"></div>
              <span class="absolute bottom-5 left-5 text-white font-bold uppercase tracking-[0.12em] text-xs border border-white/60 px-4 py-2 rounded-full backdrop-blur-sm translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                Vezi detalii →
              </span>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-extrabold text-[#0a0a0b] mb-1 group-hover:text-[#cc0000] transition-colors" style="font-family:'Plus Jakarta Sans',sans-serif">{cat.name}</h3>
              <p class="text-sm text-slate-500">{cat.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PAȘI DE ÎNSCRIERE ==================== -->
  <section class="py-24 sm:py-28 bg-slate-50/40 relative overflow-hidden">
    <div class="container-wide max-w-6xl px-4">
      <SectionHeading eyebrow="Cum Funcționează" title="Cum te înscrii la școala de șoferi" intro="De la prima discuție până la permis — un proces clar, fără surprize." />

      <div class="relative mt-20">
        
        {steps.map((step, i) => {
          const isEven = (i & 1) === 0;
          const displayNum = String(i + 1).padStart(2, '0');
          const isLast = i === steps.length - 1;

          return (
            <div class="relative flex flex-col md:flex-row items-start gap-6 md:gap-0 mb-16 md:mb-24 last:mb-0 group">
              
              {/* Desktop S-Curve Dotted Connectors */}
              {!isLast && (
                <div class="absolute top-[68px] left-1/2 -translate-x-1/2 w-40 z-10 hidden md:block" style="bottom: -104px;">
                  <svg viewBox="0 0 100 100" preserveAspectRatio="none" class="w-full h-full text-[#cc0000]/25" fill="none">
                    {isEven ? (
                      <path d="M 50 0 C 95 15, 95 85, 50 100" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="animate-line-flow" />
                    ) : (
                      <path d="M 50 0 C 5 15, 5 85, 50 100" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="animate-line-flow" />
                    )}
                  </svg>
                </div>
              )}

              {/* Mobile Vertical Dotted Line */}
              {!isLast && (
                <div class="absolute left-6 top-14 bottom-[-64px] w-px border-l-2 border-dashed border-[#cc0000]/20 md:hidden z-10"></div>
              )}

              {/* Central/Left Icon Badge */}
              <div class="absolute left-0 md:left-1/2 -translate-x-0 md:-translate-x-1/2 top-1 md:top-2 z-20 flex flex-col items-center justify-start">
                <div class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-slate-950 text-white border-[3px] md:border-4 border-white flex items-center justify-center shadow-lg relative z-20 group-hover:bg-[#cc0000] group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(204,0,0,0.35)] transition-all duration-500">
                  {/* Brand Steering Wheel SVG */}
                  <svg viewBox="0 0 44 44" fill="none" class="w-6 h-6 md:w-8 md:h-8 transition-transform duration-700 ease-out group-hover:rotate-180" aria-hidden="true">
                    <circle cx="22" cy="22" r="12.5" stroke="#ffffff" stroke-width="2.4" opacity="0.95" />
                    <circle cx="22" cy="22" r="3.4" fill="#ffffff" />
                    <path d="M22 22 L22 9.5 M22 22 L31.5 27.5 M22 22 L12.5 27.5" stroke="#ffffff" stroke-width="2.4" stroke-linecap="round" opacity="0.95" />
                  </svg>
                </div>
              </div>

              {/* Content Card (alternates left/right on desktop) */}
              <div class={`w-full md:w-[calc(50%-48px)] pl-16 md:pl-0 ${isEven ? 'md:mr-auto md:text-right' : 'md:ml-auto md:text-left'}`}>
                <div class="bg-white border border-slate-200/60 rounded-2xl p-6 md:p-8 shadow-[0_4px_20px_rgba(0,0,0,0.015)] transition-all duration-300 hover:shadow-[0_12px_30px_rgba(204,0,0,0.06)] hover:border-red-500/20 relative group/card overflow-hidden">
                  
                  {/* Decorative Number for Mobile */}
                  <span class="absolute right-6 bottom-2 text-6xl font-black text-transparent opacity-[0.07] select-none md:hidden" style="-webkit-text-stroke: 1.5px #cc0000; font-family:'Plus Jakarta Sans',sans-serif;">
                    {displayNum}
                  </span>

                  {/* Header for Desktop */}
                  <div class={`hidden md:flex items-center gap-3 mb-3 ${isEven ? 'md:justify-end' : 'md:justify-start'}`}>
                    {isEven ? (
                      <>
                        <h3 class="text-lg md:text-xl font-bold text-[#0a0a0b] group-hover/card:text-[#cc0000] transition-colors duration-300">
                          {step.title}
                        </h3>
                        <span class="text-2xl shrink-0">{step.icon}</span>
                      </>
                    ) : (
                      <>
                        <span class="text-2xl shrink-0">{step.icon}</span>
                        <h3 class="text-lg md:text-xl font-bold text-[#0a0a0b] group-hover/card:text-[#cc0000] transition-colors duration-300">
                          {step.title}
                        </h3>
                      </>
                    )}
                  </div>

                  {/* Header for Mobile */}
                  <div class="flex items-center gap-3 mb-2.5 md:hidden">
                    <span class="text-2xl shrink-0">{step.icon}</span>
                    <h3 class="text-lg font-bold text-[#0a0a0b]">
                      {step.title}
                    </h3>
                  </div>
                  
                  <p class="text-slate-500 text-sm md:text-base leading-relaxed font-light">
                    {step.desc}
                  </p>
                </div>
              </div>

              {/* Decorative Outline Number for Desktop (positioned on opposite side) */}
              <div class={`hidden md:flex items-center w-[calc(50%-48px)] h-16 md:h-20 ${isEven ? 'absolute right-0 top-0 pl-16 justify-start text-left' : 'absolute left-0 top-0 pr-16 justify-end text-right'}`}>
                <span class="text-8xl lg:text-9xl font-black text-transparent opacity-15 group-hover:opacity-30 transition-opacity duration-300 select-none" style="-webkit-text-stroke: 2px #cc0000; font-family:'Plus Jakarta Sans',sans-serif;">
                  {displayNum}
                </span>
              </div>

            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* Local Styles for SVG dash flow animation */}
  <style>
    @keyframes line-flow {
      from {
        stroke-dashoffset: 24;
      }
      to {
        stroke-dashoffset: 0;
      }
    }
    .animate-line-flow {
      stroke-dasharray: 8, 8;
      animation: line-flow 1.5s linear infinite;
    }
  </style>

  <!-- ==================== INSTRUCTORI ==================== -->
  <section class="py-24 sm:py-28 bg-[#f6f6f7]">
    <div class="container-wide">
      <SectionHeading eyebrow="Echipa Noastră" title="Instructorii Start Drive" intro="Profesioniști cu sute de absolvenți și zeci de ani de experiență la volan." />

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {instructors.map((inst, i) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 group reveal" style={`transition-delay:${i * 90}ms`}>
            <div class="relative h-60 overflow-hidden bg-slate-100">
              <img src={inst.image} alt={inst.name} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute top-4 right-4 bg-[#cc0000] text-white text-xs font-bold px-3 py-1 rounded-full shadow">
                {inst.experience} ani
              </div>
            </div>
            <div class="p-6 text-center">
              <h3 class="text-lg font-extrabold text-[#0a0a0b] mb-1" style="font-family:'Plus Jakarta Sans',sans-serif">{inst.name}</h3>
              <p class="text-[#cc0000] text-xs font-semibold mb-3 uppercase tracking-[0.08em]">{inst.role}</p>
              <div class="flex justify-center gap-6 pt-3 border-t border-slate-100">
                <div>
                  <p class="text-lg font-extrabold text-[#0a0a0b]" style="font-family:'Plus Jakarta Sans',sans-serif">{inst.students}</p>
