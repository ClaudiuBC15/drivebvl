  <!-- ===== FAQ SECTION ===== -->
  <section class="py-14 md:py-20 bg-slate-50/50 border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header Row -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14 reveal">
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[#0a0a0b] tracking-tight" style="font-family:'Plus Jakarta Sans',sans-serif;">
            Întrebări <span class="text-[#cc0000]">frecvente</span>
          </h2>
          <div class="w-10 h-[3px] bg-[#cc0000] rounded-full mt-4"></div>
        </div>
        <a href="/intrebari-frecvente" class="text-[#cc0000] font-bold text-sm hover:underline flex items-center gap-1.5 shrink-0 self-start sm:self-auto group">
          Vezi toate întrebările
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <!-- FAQ Grid 2 columns -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {faqs.length > 0 ? faqs.map((faq, idx) => (
          <div class="bg-white border border-slate-200/80 rounded-2xl overflow-hidden reveal" style={`transition-delay:${idx * 40}ms`}>
            <button
              class="faq-toggle w-full text-left px-6 py-4 font-bold text-[#0a0a0b] hover:text-[#cc0000] flex items-center justify-between gap-3 transition-colors focus:outline-none group"
              aria-expanded="false"
              data-target={`faq-content-${idx}`}
            >
              <div class="flex items-center gap-3 text-sm">
                <div class="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                {faq.question}
              </div>
              <svg class="w-4 h-4 text-slate-400 transform transition-transform duration-200 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id={`faq-content-${idx}`} class="faq-content hidden px-6 pb-5 text-slate-600 font-light text-sm leading-relaxed border-t border-slate-50 pt-3 pl-[3.75rem]">
              {faq.answer}
            </div>
          </div>
        )) : (
          <div class="col-span-2 text-center py-12 text-slate-400 text-sm">Nu există întrebări disponibile momentan.</div>
        )}
      </div>

    </div>
  </section>

  <!-- ===== DARK CTA BANNER ===== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="bg-[#0a0a0b] rounded-[32px] overflow-hidden relative shadow-2xl">

        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center px-8 md:px-14 py-14 md:py-16">

          <!-- Text -->
          <div class="lg:col-span-8 space-y-3">
            <p class="text-[#cc0000] text-xs font-bold uppercase tracking-widest">Start Drive BVL</p>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-black text-white leading-tight" style="font-family:'Plus Jakarta Sans',sans-serif;">
              Hai să ne ocupăm noi de birocrație.<br class="hidden md:block"/> Tu concentrează-te pe condus.
            </h2>
            <p class="text-slate-400 font-light text-sm md:text-base leading-relaxed max-w-xl">
              Completezi un formular simplu, iar noi ne ocupăm de tot restul — documente, programări, examene.
            </p>
          </div>

          <!-- Actions -->
          <div class="lg:col-span-4 flex flex-col gap-4">
            <a href="#inscriere-form"
              class="inline-flex items-center justify-center gap-2 bg-[#cc0000] hover:bg-red-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-200 shadow-lg shadow-red-950/30 text-sm uppercase tracking-wider cursor-pointer select-none group">
              Înscrie-te acum
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <p class="text-slate-500 text-xs text-center lg:text-left">
              Sau sună direct: <a href={`tel:${settings.contact_phone.replace(/\s+/g,'')}`} class="text-white font-bold hover:text-[#cc0000] transition-colors">{settings.contact_phone}</a>
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <style>
    /* Fade-up on reveal */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Step icon pulse on viewport entry */
    .step-card.is-visible .step-icon-wrap {
      animation: icon-pulse 0.5s ease-out forwards;
    }
    @keyframes icon-pulse {
      0%   { transform: scale(0.85); }
      60%  { transform: scale(1.08); }
      100% { transform: scale(1); }
    }

    /* Card hover glow */
    .process-card:hover {
      box-shadow: 0 12px 30px rgba(204,0,0,0.07), 0 0 0 1px rgba(204,0,0,0.08);
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {

      // ===== SCROLL REVEAL =====
      const reveals = document.querySelectorAll('.reveal');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach(el => revealObserver.observe(el));

      // ===== SVG WAVE SCROLL ANIMATION =====
      const fillPath = document.getElementById('stepper-wave-fill');
      const stepsSection = document.getElementById('cum-functioneaza');
      if (fillPath && stepsSection) {
        const pathLen = 1400;
        fillPath.style.strokeDasharray = pathLen;
        fillPath.style.strokeDashoffset = pathLen;
        const pathObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              fillPath.style.strokeDashoffset = '0';
              pathObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        pathObserver.observe(stepsSection);
      }

      // ===== MULTI-STEP FORM =====
      const stepTitles = ['Informații personale', 'Mesaj opțional', 'Confirmă trimiterea'];
      let currentStep = 1;
      const totalSteps = 3;

      const stepLabel = document.getElementById('step-label');
      const stepTitle = document.getElementById('step-title');
      const btnPrev = document.getElementById('btn-prev');
      const btnNext = document.getElementById('btn-next');
      const formStatus = document.getElementById('form-status');
      const summaryPreview = document.getElementById('summary-preview');

      function updateStepUI() {
        if (!stepLabel || !stepTitle) return;
        stepLabel.textContent = `Pasul ${currentStep} din ${totalSteps}`;
        stepTitle.textContent = stepTitles[currentStep - 1];

        document.querySelectorAll('.form-step').forEach((s, i) => {
          s.classList.toggle('hidden', i + 1 !== currentStep);
        });
        document.querySelectorAll('.step-dot').forEach((dot, i) => {
          const n = i + 1;
          if (n < currentStep) {
            dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-black transition-all duration-300 bg-green-500 text-white';
            dot.textContent = '✓';
          } else if (n === currentStep) {
            dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-black transition-all duration-300 bg-[#cc0000] text-white shadow-md shadow-red-200';
            dot.textContent = n;
          } else {
            dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-black transition-all duration-300 bg-slate-100 text-slate-400';
            dot.textContent = n;
          }
        });

        if (btnPrev) btnPrev.classList.toggle('hidden', currentStep === 1);

        if (btnNext) {
          if (currentStep < totalSteps) {
            btnNext.innerHTML = 'Continuă <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>';
          } else {
            btnNext.innerHTML = 'Trimite înscrierea <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
          }
        }

        if (currentStep === 3 && summaryPreview) {
          const name = document.getElementById('field-name')?.value || '—';
          const phone = document.getElementById('field-phone')?.value || '—';
          const email = document.getElementById('field-email')?.value || '—';
          const category = document.getElementById('field-category')?.value || '—';
          summaryPreview.innerHTML = `
            <div class="space-y-1 text-slate-600">
              <p class="text-xs"><span class="font-bold text-slate-800">Nume:</span> ${name}</p>
              <p class="text-xs"><span class="font-bold text-slate-800">Telefon:</span> ${phone}</p>
              <p class="text-xs"><span class="font-bold text-slate-800">Email:</span> ${email}</p>
              <p class="text-xs"><span class="font-bold text-slate-800">Categorie:</span> ${category}</p>
            </div>`;
        }
      }

      if (btnNext) {
        btnNext.addEventListener('click', async () => {
          if (currentStep < totalSteps) {
            // Basic validation step 1
            if (currentStep === 1) {
              const name = document.getElementById('field-name')?.value.trim();
              const phone = document.getElementById('field-phone')?.value.trim();
              if (!name || !phone) {
                if (formStatus) {
                  formStatus.className = 'text-sm font-semibold p-3 rounded-xl bg-red-50 border border-red-200 text-red-600';
                  formStatus.textContent = 'Completează cel puțin Numele și Telefonul.';
                  formStatus.classList.remove('hidden');
                }
                return;
              }
            }
            if (formStatus) formStatus.classList.add('hidden');
            currentStep++;
            updateStepUI();
          } else {
            // Submit
            const name = document.getElementById('field-name')?.value.trim();
            const phone = document.getElementById('field-phone')?.value.trim();
            const email = document.getElementById('field-email')?.value.trim();
            const category = document.getElementById('field-category')?.value;
            const message = document.getElementById('field-message')?.value.trim();

            if (!name || !phone) {
              if (formStatus) {
                formStatus.className = 'text-sm font-semibold p-3 rounded-xl bg-red-50 border border-red-200 text-red-600';
                formStatus.textContent = 'Completează cel puțin Numele și Telefonul.';
                formStatus.classList.remove('hidden');
              }
              return;
            }

            if (btnNext) {
              btnNext.disabled = true;
              btnNext.innerHTML = '<div class="w-4 h-4 rounded-full border-2 border-white border-t-transparent animate-spin"></div> Se trimite...';
            }

            try {
              const res = await fetch('/api/leads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, phone, email, category, message, source: 'website' })
              });

              if (res.ok) {
                if (formStatus) {
                  formStatus.className = 'text-sm font-semibold p-3 rounded-xl bg-green-50 border border-green-200 text-green-700';
                  formStatus.innerHTML = '✓ Cererea ta a fost trimisă cu succes! Te contactăm în cel mai scurt timp.';
                  formStatus.classList.remove('hidden');
                }
                document.getElementById('inscriere-form')?.reset();
                currentStep = 1;
                updateStepUI();
                if (btnNext) btnNext.disabled = false;
              } else {
                throw new Error('server error');
              }
            } catch (err) {
              if (formStatus) {
                formStatus.className = 'text-sm font-semibold p-3 rounded-xl bg-red-50 border border-red-200 text-red-600';
                formStatus.textContent = 'A apărut o eroare. Încearcă din nou sau sună la ' + '{settings.contact_phone}'.replace('{settings.contact_phone}', '0744 420 905');
                formStatus.classList.remove('hidden');
              }
              if (btnNext) {
                btnNext.disabled = false;
                btnNext.innerHTML = 'Trimite înscrierea <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
              }
            }
          }
        });
      }

      if (btnPrev) {
        btnPrev.addEventListener('click', () => {
          if (currentStep > 1) {
            currentStep--;
            if (formStatus) formStatus.classList.add('hidden');
            updateStepUI();
          }
        });
      }

      updateStepUI();

      // ===== FAQ ACCORDION =====
      document.querySelectorAll('.faq-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const targetId = toggle.getAttribute('data-target');
          const content = document.getElementById(targetId);
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          const svg = toggle.querySelector('svg');
          if (svg) svg.classList.toggle('rotate-180', !expanded);
          if (content) content.classList.toggle('hidden', expanded);
          toggle.setAttribute('aria-expanded', !expanded);
        });
      });

    });
  </script>

</MainLayout>
