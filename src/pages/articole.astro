---
import MainLayout from '../layouts/main.astro';

const articole = [
  {
    title: "Cum să te pregătești pentru examenul practic de conducere: Sfaturi și Trucuri",
    category: "SFATURI",
    date: "01 sept., 2024",
    author: "admin",
    excerpt: "Obținerea permisului auto poate fi un pas important și emoționant în viața ta. Unul dintre cele mai așteptate momente este examenul practic de conducere, în care vei fi evaluat pe abilitățile tale de conducere în situații reale de trafic. Pentru a te asigura că ești pregătit și încrezător în timpul examenului, iată câteva sfaturi și [...]",
    image: "https://i.imgur.com/TNY8kty.jpeg"
  },
  {
    title: "Cum să te pregătești pentru întrebările teoretice la examenul pentru permisul auto",
    category: "LEGISLAȚIE",
    date: "29 sept., 2024",
    author: "admin",
    excerpt: "Examenul teoretic este prima probă majoră înainte de a urca la volan alături de examinator. Deși mulți cursanți îl subestimează, necesită un studiu riguros al codului rutier. Iată ce metodologie de învățare te poate ajuta să reții eficient informația și să eviți emoțiile la sală [...]",
    image: "https://i.imgur.com/SsZQl1w.jpeg"
  },
  {
    title: "Recomandări pentru alegerea unui instructor auto potrivit",
    category: "SFATURI",
    date: "22 iul., 2024",
    author: "admin",
    excerpt: "Instructorul tău va juca un rol crucial nu doar în obținerea permisului, ci și în formarea ta ca șofer responsabil pe termen lung. Cum știi dacă stilul său de predare ți se potrivește? Descoperă ce întrebări să pui înainte de a semna fișa de școlarizare [...]",
    image: "https://i.imgur.com/a7H0dcY.jpeg"
  }
];

const categorii = [
  "SFATURI",
  "LEGISLAȚIE",
  "NOUTĂȚI AUTO",
  "EXAMENE"
];

const postariPopulare = [
  {
    title: "Cum să te pregătești pentru întrebările teoretice la examenul pentru permisul auto",
    date: "29 sept., 24",
    image: "https://i.imgur.com/SsZQl1w.jpeg"
  },
  {
    title: "Cum să te pregătești pentru examenul practic de conducere: Sfaturi și Trucuri",
    date: "01 sept., 24",
    image: "https://i.imgur.com/TNY8kty.jpeg"
  },
  {
    title: "Recomandări pentru alegerea unui instructor auto potrivit",
    date: "22 iul., 24",
    image: "https://i.imgur.com/a7H0dcY.jpeg"
  }
];
---

<MainLayout title="Articole - Start Drive BVL">
  <!-- Hero Banner (Ovasal Style) -->
  <div class="relative w-full h-[400px] bg-slate-900 overflow-hidden flex flex-col justify-center items-center">
    <div class="absolute inset-0 bg-[url('https://i.imgur.com/dxsvS4U.jpeg')] bg-cover bg-center bg-no-repeat opacity-50 mix-blend-overlay"></div>
    <div class="absolute inset-0 bg-black/40"></div>
    
    <div class="relative z-10 text-center flex flex-col items-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-wide mb-6">Articole - Start Drive BVL</h1>
      <div class="flex items-center gap-2 text-white font-bold text-sm tracking-widest uppercase">
        <a href="/" class="hover:text-[#cc0000] transition-colors">HOME</a>
        <span class="text-white">&gt;</span>
        <span class="text-white">ARTICOLE</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-20 flex flex-col lg:flex-row gap-12">
    <!-- Left Column (Main Content) -->
    <div class="w-full lg:w-[65%] space-y-14">
      {articole.map(articol => (
        <article class="bg-white rounded-sm shadow-sm flex flex-col group">
          <div class="relative w-full aspect-[16/9] md:h-[450px] overflow-hidden bg-slate-100">
            <img src={articol.image} alt={articol.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
            <!-- Category Badge (Red to match brand) -->
            <div class="absolute top-0 left-0 bg-[#cc0000] text-white text-xs font-bold px-6 py-2 tracking-widest uppercase shadow-md">
              {articol.category}
            </div>
          </div>
          
          <div class="pt-8 pb-6 px-2">
            <h2 class="text-3xl font-bold text-[#cc0000] mb-5 leading-snug hover:text-[#a30000] transition-colors cursor-pointer">
              {articol.title}
            </h2>
            <p class="text-slate-600 leading-loose font-light mb-8 text-[15px]">
              {articol.excerpt}
            </p>
            
            <div class="flex items-center justify-between border-t border-slate-200 pt-5 text-sm text-slate-500">
              <div class="flex items-center gap-6">
                <!-- Date -->
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <span>{articol.date}</span>
                </div>
                <!-- Author -->
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  <span>{articol.author}</span>
                </div>
              </div>
              
              <!-- Share Icon -->
              <button class="hover:text-[#cc0000] transition-colors p-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Right Column (Sidebar) -->
    <div class="w-full lg:w-[35%] space-y-12">
      <!-- Cauta -->
      <div>
        <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span class="text-[#cc0000] font-normal text-lg">&gt;</span> Caută
        </h3>
        <div class="relative">
          <input type="text" placeholder="Cuvânt cheie..." class="w-full border border-slate-200 py-4 px-5 text-sm rounded-sm focus:outline-none focus:border-[#cc0000] transition-colors placeholder:text-slate-400 bg-slate-50/50" />
          <button class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-[#cc0000]">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
        </div>
      </div>

      <!-- Categorii -->
      <div>
        <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span class="text-[#cc0000] font-normal text-lg">&gt;</span> Categorii
        </h3>
        <ul class="space-y-4">
          {categorii.map(cat => (
            <li class="flex items-center gap-3">
              <div class="w-3.5 h-3.5 border-[1.5px] border-slate-300 rounded-sm"></div>
              <a href="#" class="text-xs font-bold text-slate-500 uppercase hover:text-[#cc0000] transition-colors">{cat}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Postari Populare -->
      <div>
        <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <span class="text-[#cc0000] font-normal text-lg">&gt;</span> Postări populare
        </h3>
        <div class="space-y-6">
          {postariPopulare.map(post => (
            <div class="flex items-start gap-4 group cursor-pointer">
              <div class="w-[90px] h-[75px] shrink-0 overflow-hidden rounded-sm bg-slate-100">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              </div>
              <div class="flex flex-col pt-1">
                <div class="flex items-center gap-1.5 text-xs text-slate-400 mb-1.5 font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <span>{post.date}</span>
                </div>
                <h4 class="text-sm font-bold text-slate-800 leading-snug group-hover:text-[#cc0000] transition-colors line-clamp-2">
                  {post.title}
                </h4>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</MainLayout>
