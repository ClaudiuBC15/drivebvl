---
import MainLayout from '../layouts/main.astro';
import { getDB, queryAll } from '../lib/db';

export const prerender = false;

const db = getDB(Astro.locals);
const faqs = await queryAll<any>(db, 'SELECT * FROM faqs ORDER BY sort_order ASC, id ASC');

// Extract categories in priority order
const categories = [
  'Toate',
  'Înscriere',
  'Costuri',
  'Acte necesare',
  'Examen teoretic',
  'Examen practic',
  'Categoria B',
  'Categoria C/CE',
  'Categoria D',
  'Program cursuri',
  'Ședințe suplimentare'
];

// Generate JSON-LD FAQ schema for search engines and AI engines
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<MainLayout 
  title="Întrebări Frecvente | Școala de Șoferi Start Drive BVL Suceava"
  description="Totul despre înscriere, acte necesare, costuri, ore de conducere, examene teoretice și practice pentru categoriile B, BE, C, CE și D la Start Drive BVL."
>
  <!-- SEO/AEO JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline></script>

  <!-- Hero Section -->
  <section class="relative bg-white pt-28 pb-16 md:pt-36 md:pb-24 overflow-hidden border-b border-slate-100">
    <!-- Grid pattern background decoration -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left Column: Title & Search Bar -->
      <div class="lg:col-span-7 text-left space-y-6 animate-fade-in-up">
        <div>
          <span class="text-[#cc0000] font-bold text-xs uppercase tracking-wider block mb-2">FAQ</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-4">
            Întrebări frecvente <br/>
            <span class="text-[#cc0000]">răspunsuri clare</span>
          </h1>
          <p class="text-slate-600 font-light text-base md:text-lg max-w-xl leading-relaxed">
            Am adunat cele mai frecvente întrebări pentru a-ți oferi informațiile de care ai nevoie rapid și simplu.
          </p>
        </div>
        
        <!-- Live Search Input -->
        <div class="relative max-w-xl">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input 
            type="text" 
            id="faq-search"
            placeholder="Caută o întrebare..."
            class="w-full bg-slate-50 border border-slate-200 rounded-2xl pl-12 pr-12 py-4 text-slate-800 placeholder-slate-400 shadow-sm focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-base font-light"
          />
          <button 
            id="search-clear" 
            class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 hidden cursor-pointer focus:outline-none"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Right Column: Hero Photo -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay: 0.15s;">
        <div class="relative max-w-sm md:max-w-md w-full">
          <!-- Background decorative shapes -->
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-red-100 rounded-3xl -z-10 blur-xl opacity-60"></div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-slate-100 rounded-full -z-10 blur-2xl opacity-80"></div>
          
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border-[6px] border-white bg-slate-100">
            <img 
              src="/images/faq_hero.png" 
              alt="Instructor auto explicând traseul" 
              class="w-full aspect-[4/3] object-cover"
            />
            <!-- Fade overlay matching mockup transition -->
            <div class="absolute inset-y-0 left-0 w-1/4 bg-gradient-to-r from-white/10 to-transparent pointer-events-none hidden lg:block"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Categories Scroll Bar -->
  <section class="bg-[#fafafa] py-6 border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="overflow-x-auto pb-2 -mx-6 px-6 no-scrollbar">
        <div class="flex gap-2.5 min-w-max">
          {categories.map((cat, idx) => (
            <button
              class={`faq-category-btn px-4.5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider border transition-all duration-200 cursor-pointer select-none whitespace-nowrap ${
                idx === 0 
                  ? 'bg-[#cc0000] border-[#cc0000] text-white shadow-md shadow-red-900/10' 
                  : 'bg-white border-slate-200 text-slate-600 hover:border-slate-300 hover:text-slate-800'
              }`}
              data-category={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Main Split Content Grid -->
  <section id="faq-section" class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Accordion list -->
      <div class="lg:col-span-8 space-y-4">
        <div class="space-y-4" id="faq-list">
          {faqs.map((faq, index) => {
            // Function to generate matching mockup category icons inline
            const getCategoryIcon = (category: string) => {
              const cat = (category || '').toLowerCase();
              if (cat.includes('înscriere')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`;
              }
              if (cat.includes('acte') || cat.includes('document')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`;
              }
              if (cat.includes('costuri') || cat.includes('plăț') || cat.includes('rate')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>`;
              }
              if (cat.includes('examen') || cat.includes('teoretic') || cat.includes('practic')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`;
              }
              if (cat.includes('program') || cat.includes('durat') || cat.includes('ore')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
              }
              if (cat.includes('categoria')) {
                return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 12m-3 0a3 3 0 1 0 6 0 3 3 0 1 0 -6 0" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v7M2 12h7M12 15v7M15 12h7" /></svg>`;
              }
              return `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
            };

            return (
              <div 
                class="faq-item bg-white border border-slate-200/80 rounded-2xl overflow-hidden transition-all duration-300 shadow-[0_2px_8px_rgba(0,0,0,0.01)]"
                data-cat={faq.category}
              >
                <button 
                  class="faq-trigger w-full flex items-center justify-between p-5 text-left hover:bg-slate-50/30 transition-colors focus:outline-none group cursor-pointer"
                  aria-expanded="false"
                >
                  <div class="flex items-center gap-4 pr-4">
                    <!-- Rounded outline badge with category matched icon -->
                    <div class="w-10 h-10 rounded-full border border-red-150 bg-red-50 text-[#cc0000] flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform" set:html={getCategoryIcon(faq.category)}>
                    </div>
                    <span class="text-sm md:text-base font-bold text-slate-800 group-hover:text-[#cc0000] transition-colors leading-snug">
                      {faq.question}
                    </span>
                  </div>
                  <svg class="faq-arrow w-5 h-5 text-slate-400 transform transition-transform duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="faq-content-wrapper max-h-0 overflow-hidden transition-all duration-350 ease-in-out">
                  <div class="px-5 pb-5 pl-[4.5rem] text-slate-550 font-light leading-relaxed text-sm md:text-base border-t border-slate-50/50 pt-3">
                    {faq.answer}
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- No Results State -->
        <div id="faq-empty-state" class="hidden text-center py-16 bg-slate-50/50 rounded-2xl border border-slate-200/60 p-8">
          <div class="w-16 h-16 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-800 mb-1">Nu s-a găsit niciun rezultat</h3>
          <p class="text-slate-500 font-light text-sm">Încearcă alte cuvinte cheie sau selectează altă categorie.</p>
        </div>
      </div>

      <!-- Right Column: Sidebar -->
      <div class="lg:col-span-4 space-y-8">
        <!-- Widget 1: Need Help? -->
        <div class="bg-white rounded-3xl border border-slate-250/60 p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] space-y-6">
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Ai nevoie de ajutor?</h3>
            <p class="text-xs text-slate-500 font-light leading-relaxed">
              Echipa noastră îți stă la dispoziție pentru orice întrebare.
            </p>
          </div>

          <div class="space-y-4">
            <!-- Phone -->
            <a href="tel:0744420905" class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-full bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 group-hover:scale-105 transition-transform shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <span class="font-extrabold text-slate-800 text-sm group-hover:text-[#cc0000] transition-colors block">0744 420 905</span>
                <span class="text-[11px] text-slate-400 block mt-0.5">Sună acum!</span>
              </div>
            </a>

            <!-- Email -->
            <a href="mailto:contact@startdrivebvl.ro" class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-full bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 group-hover:scale-105 transition-transform shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <span class="font-extrabold text-slate-800 text-sm group-hover:text-[#cc0000] transition-colors block truncate max-w-[190px]">contact@startdrivebvl.ro</span>
                <span class="text-[11px] text-slate-400 block mt-0.5">Răspundem rapid</span>
              </div>
            </a>

            <!-- Location -->
            <a href="https://www.google.com/maps/search/?api=1&query=47.64761027691624,26.252242589241373" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
              <div class="w-10 h-10 rounded-full bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 group-hover:scale-105 transition-transform shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <span class="font-extrabold text-slate-800 text-sm group-hover:text-[#cc0000] transition-colors block">Strada Mărăști, Nr. 12, Bl. T2, Suceava (pe Mărășești, în parcarea MPO)</span>
                <span class="text-[11px] text-slate-400 block mt-0.5">Vezi pe hartă</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Widget 2: Popular Categories -->
        <div class="bg-white rounded-3xl border border-slate-250/60 p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)]">
          <h3 class="text-xl font-bold text-slate-900 mb-6">Categorie populară de întrebări</h3>
          
          <div class="space-y-1">
            <!-- 1. Înscriere și acte -->
            <a href="#" class="sidebar-category-link flex justify-between items-center py-3.5 border-b border-slate-100 group cursor-pointer text-slate-700 hover:text-[#cc0000] font-medium text-sm transition-colors" data-category="Înscriere">
              <span>Înscriere și acte</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-1 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <!-- 2. Cursuri și program -->
            <a href="#" class="sidebar-category-link flex justify-between items-center py-3.5 border-b border-slate-100 group cursor-pointer text-slate-700 hover:text-[#cc0000] font-medium text-sm transition-colors" data-category="Program cursuri">
              <span>Cursuri și program</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-1 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <!-- 3. Ore de conducere -->
            <a href="#" class="sidebar-category-link flex justify-between items-center py-3.5 border-b border-slate-100 group cursor-pointer text-slate-700 hover:text-[#cc0000] font-medium text-sm transition-colors" data-category="Ședințe suplimentare">
              <span>Ore de conducere</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-1 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <!-- 4. Examen auto -->
            <a href="#" class="sidebar-category-link flex justify-between items-center py-3.5 border-b border-slate-100 group cursor-pointer text-slate-700 hover:text-[#cc0000] font-medium text-sm transition-colors" data-category="Examen teoretic">
              <span>Examen auto</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-1 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <!-- 5. Plăți și oferte -->
            <a href="#" class="sidebar-category-link flex justify-between items-center py-3.5 group cursor-pointer text-slate-700 hover:text-[#cc0000] font-medium text-sm transition-colors" data-category="Costuri">
              <span>Plăți și oferte</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-1 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Widget 3: Visit Schedule -->
        <div class="bg-red-50/40 rounded-3xl border border-red-100/50 p-8 shadow-sm flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-xl bg-red-100 text-[#cc0000] flex items-center justify-center mb-4 shrink-0 shadow-sm">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h4 class="text-lg font-bold text-slate-900 mb-2">Programează-te la noi</h4>
          <p class="text-xs text-slate-600 font-light leading-relaxed mb-6 max-w-xs">
            Vino la sediu pentru informații complete și înscriere rapidă.
          </p>
          <a 
            href="/contact" 
            class="w-full bg-[#cc0000] hover:bg-red-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg focus:outline-none flex items-center justify-center gap-2 cursor-pointer select-none text-xs uppercase tracking-wider"
          >
            Programează o vizită
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="bg-white pb-16 md:pb-24 border-t border-slate-100 pt-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="relative bg-gradient-to-r from-red-950 via-[#cc0000] to-red-900 rounded-3xl p-8 md:p-12 shadow-xl overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
        <!-- Background car image overlay with low opacity -->
        <div class="absolute inset-0 bg-[url('/images/about-car.png')] bg-cover bg-center mix-blend-overlay opacity-10"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/20 via-transparent to-black/20"></div>
        
        <div class="relative z-10 space-y-2">
          <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">Pregătit să începi?</h2>
          <p class="text-red-100 font-light text-sm md:text-base max-w-md leading-relaxed">
            Înscrie-te acum și fă primul pas către permisul tău.
          </p>
        </div>
        
        <div class="relative z-10 shrink-0">
          <a 
            href="/inscrieri" 
            class="inline-flex items-center gap-2 bg-white hover:bg-slate-50 text-[#cc0000] font-bold py-3.5 px-8 rounded-xl transition-all duration-200 shadow-lg text-sm select-none"
          >
            Înscrie-te gratuit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Hide scrollbar utility */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('faq-search');
      const searchClear = document.getElementById('search-clear');
      const categoryButtons = document.querySelectorAll('.faq-category-btn');
      const faqItems = document.querySelectorAll('.faq-item');
      const emptyState = document.getElementById('faq-empty-state');
      
      let currentCategory = 'Toate';
      let searchQuery = '';

      // Accordion toggle logic with maxHeight transition for premium feel
      faqItems.forEach(item => {
        const trigger = item.querySelector('.faq-trigger');
        const wrapper = item.querySelector('.faq-content-wrapper');
        const arrow = item.querySelector('.faq-arrow');

        trigger.addEventListener('click', () => {
          const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
          
          // Close all other active FAQ items
          faqItems.forEach(otherItem => {
            if (otherItem !== item) {
              const otherTrigger = otherItem.querySelector('.faq-trigger');
              const otherWrapper = otherItem.querySelector('.faq-content-wrapper');
              const otherArrow = otherItem.querySelector('.faq-arrow');
              otherTrigger.setAttribute('aria-expanded', 'false');
              otherWrapper.style.maxHeight = '0px';
              otherArrow.classList.remove('rotate-180');
            }
          });

          // Toggle current
          if (!isExpanded) {
            trigger.setAttribute('aria-expanded', 'true');
            wrapper.style.maxHeight = wrapper.scrollHeight + 'px';
            arrow.classList.add('rotate-180');
          } else {
            trigger.setAttribute('aria-expanded', 'false');
            wrapper.style.maxHeight = '0px';
            arrow.classList.remove('rotate-180');
          }
        });
      });

      // Filter & Search runner
      function filterFaqItems() {
        let visibleCount = 0;

        faqItems.forEach(item => {
          const itemCat = item.getAttribute('data-cat') || '';
          const questionText = item.querySelector('.faq-trigger span:last-child').textContent.toLowerCase();
          const answerText = item.querySelector('.faq-content-wrapper').textContent.toLowerCase();
          
          const matchesCategory = currentCategory === 'Toate' || itemCat.toLowerCase() === currentCategory.toLowerCase() || (currentCategory === 'Categoria C/CE' && (itemCat.toLowerCase() === 'categoria c' || itemCat.toLowerCase() === 'categoria ce'));
          const matchesSearch = questionText.includes(searchQuery) || answerText.includes(searchQuery);

          if (matchesCategory && matchesSearch) {
            item.classList.remove('hidden');
            visibleCount++;
          } else {
            item.classList.add('hidden');
            // Force collapse if hidden
            const trigger = item.querySelector('.faq-trigger');
            const wrapper = item.querySelector('.faq-content-wrapper');
            const arrow = item.querySelector('.faq-arrow');
            trigger.setAttribute('aria-expanded', 'false');
            wrapper.style.maxHeight = '0px';
            arrow.classList.remove('rotate-180');
          }
        });

        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
        } else {
          emptyState.classList.add('hidden');
        }
      }

      // Handle category filtering clicks
      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Remove active styles from previous
          categoryButtons.forEach(b => {
            b.className = 'faq-category-btn px-4.5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider border transition-all duration-200 cursor-pointer select-none bg-white border-slate-200 text-slate-600 hover:border-slate-300 hover:text-slate-800';
          });

          // Set active to clicked
          btn.className = 'faq-category-btn px-4.5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider border transition-all duration-200 cursor-pointer select-none bg-[#cc0000] border-[#cc0000] text-white shadow-md shadow-red-900/10';
          
          currentCategory = btn.getAttribute('data-category') || 'Toate';
          filterFaqItems();
        });
      });

      // Sidebar popular category clicks
      const sidebarCategoryLinks = document.querySelectorAll('.sidebar-category-link');
      sidebarCategoryLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetCat = link.getAttribute('data-category') || '';
          
          // Find active category button in page scroll and click it
          const targetBtn = document.querySelector(`.faq-category-btn[data-category="${targetCat}"]`);
          if (targetBtn) {
            targetBtn.click();
            // Scroll to the main section smoothly
            document.getElementById('faq-section').scrollIntoView({ behavior: 'smooth' });
          }
        });
      });

      // Handle live search inputs
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        
        if (searchQuery.length > 0) {
          searchClear.classList.remove('hidden');
        } else {
          searchClear.classList.add('hidden');
        }
        
        filterFaqItems();
      });

      // Clear search
      searchClear.addEventListener('click', () => {
        searchInput.value = '';
        searchQuery = '';
        searchClear.classList.add('hidden');
        filterFaqItems();
        searchInput.focus();
      });
    });
  </script>
</MainLayout>
