  <!-- Client-side Accordion & Sidebar sync script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const accordionItems = document.querySelectorAll('.accordion-item');
      const tocLinks = document.querySelectorAll('.toc-link');

      // Expand specific section
      function expandItem(item: Element) {
        const content = item.querySelector('.accordion-content');
        const arrow = item.querySelector('.accordion-arrow');
        const preview = item.querySelector('.accordion-preview');
        
        if (content && content.classList.contains('hidden')) {
          content.classList.remove('hidden');
          if (arrow) arrow.classList.add('rotate-180');
          if (preview) preview.classList.add('opacity-0', 'h-0', 'overflow-hidden');
          item.classList.add('border-[#cc0000]/30', 'ring-2', 'ring-[#cc0000]/5');
        }
      }

      // Collapse specific section
      function collapseItem(item: Element) {
        const content = item.querySelector('.accordion-content');
        const arrow = item.querySelector('.accordion-arrow');
        const preview = item.querySelector('.accordion-preview');
        
        if (content && !content.classList.contains('hidden')) {
          content.classList.add('hidden');
          if (arrow) arrow.classList.remove('rotate-180');
          if (preview) preview.classList.remove('opacity-0', 'h-0', 'overflow-hidden');
          item.classList.remove('border-[#cc0000]/30', 'ring-2', 'ring-[#cc0000]/5');
        }
      }

      // Add click handler to triggers
      accordionItems.forEach(item => {
        const trigger = item.querySelector('.accordion-trigger');
        if (trigger) {
          trigger.addEventListener('click', () => {
            const content = item.querySelector('.accordion-content');
            if (content) {
              if (content.classList.contains('hidden')) {
                expandItem(item);
              } else {
                collapseItem(item);
              }
            }
          });
        }
      });

      // Toc Click Handler
      tocLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = link.getAttribute('data-target');
          if (targetId) {
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
              // Expand
              expandItem(targetElement);
              
              // Scroll to element
              targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });

              // Highlight TOC
              tocLinks.forEach(l => {
                l.classList.remove('text-[#cc0000]', 'border-[#cc0000]');
                l.classList.add('text-slate-500', 'border-transparent');
              });
              link.classList.remove('text-slate-500', 'border-transparent');
              link.classList.add('text-[#cc0000]', 'border-[#cc0000]');
            }
          }
        });
      });

      // Scroll Spy for Table of Contents
      const observerOptions = {
        root: null,
        rootMargin: '0px -10px -50% 0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            if (id) {
              const correspondingLink = document.querySelector(`.toc-link[data-target="${id}"]`);
              if (correspondingLink) {
                tocLinks.forEach(l => {
                  l.classList.remove('text-[#cc0000]', 'border-[#cc0000]');
                  l.classList.add('text-slate-500', 'border-transparent');
                });
                correspondingLink.classList.remove('text-slate-500', 'border-transparent');
                correspondingLink.classList.add('text-[#cc0000]', 'border-[#cc0000]');
              }
            }
          }
        });
      }, observerOptions);

      accordionItems.forEach(item => {
        observer.observe(item);
      });
    });
  </script>
