---
import MainLayout from '../layouts/main.astro';
---

<MainLayout title="Contact | Start Drive BVL">
  
  <!-- Hero Banner -->
  <div class="relative w-full h-[350px] bg-slate-900 overflow-hidden flex flex-col justify-center items-center">
    <div class="absolute inset-0 bg-[url('https://i.imgur.com/a7H0dcY.jpeg')] bg-cover bg-center opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 to-[#111111]"></div>
    <div class="relative z-10 text-center px-4 animate-fade-in-up">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">Contact - Start Drive BVL</h1>
      <div class="flex items-center justify-center gap-2 text-sm font-bold text-slate-300 tracking-widest uppercase">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>></span>
        <span class="text-[#cc0000]">Contact</span>
      </div>
    </div>
  </div>

  <div class="min-h-[calc(100vh-350px-6rem)] bg-[#111111] flex flex-col lg:flex-row w-full">
    
    <!-- Partea stângă: Informații Contact (Cu imagine pe fundal) -->
    <div class="relative w-full lg:w-[45%] flex flex-col justify-center px-8 py-16 md:px-16 lg:px-24">
      <div class="absolute inset-0 bg-[url('https://i.imgur.com/dxsvS4U.jpeg')] bg-cover bg-center opacity-30"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#111111] via-[#111111]/80 to-transparent"></div>
      
      <div class="relative z-10 space-y-12 animate-fade-in-up">
        
        <!-- Locatie -->
        <div>
          <div class="flex items-center gap-4 mb-2">
            <svg class="w-8 h-8 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <h3 class="text-2xl font-bold text-white tracking-wide">Suntem aici</h3>
          </div>
          <p class="text-slate-300 font-light pl-12 text-lg">Suceava, Str. Mărășești nr 48<br/><span class="text-sm">(vis a vis de Colegiul Mihai Eminescu)</span></p>
        </div>

        <!-- Contact Rapid -->
        <div>
          <div class="flex items-center gap-4 mb-2">
            <svg class="w-8 h-8 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            <h3 class="text-2xl font-bold text-white tracking-wide">Contact rapid</h3>
          </div>
          <div class="pl-12 flex flex-col gap-1">
            <a href="tel:0744420905" class="text-slate-300 font-light hover:text-[#cc0000] transition-colors text-lg">0744 420 905</a>
            <a href="mailto:scoala.bvl@gmail.com" class="text-slate-300 font-light hover:text-[#cc0000] transition-colors text-lg">scoala.bvl@gmail.com</a>
          </div>
        </div>

        <!-- Program -->
        <div>
          <div class="flex items-center gap-4 mb-2">
            <svg class="w-8 h-8 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h3 class="text-2xl font-bold text-white tracking-wide">Program de lucru</h3>
          </div>
          <p class="text-slate-300 font-light pl-12 text-lg">Luni-Vineri: 08:00 - 17:00</p>
        </div>

        <!-- Social Media -->
        <div class="pl-12 pt-4 flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white text-[#111111] flex items-center justify-center hover:bg-[#cc0000] hover:text-white transition-all transform hover:scale-110">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white text-[#111111] flex items-center justify-center hover:bg-[#cc0000] hover:text-white transition-all transform hover:scale-110">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white text-[#111111] flex items-center justify-center hover:bg-[#cc0000] hover:text-white transition-all transform hover:scale-110">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.34 2.88 2.88 0 012.31-4.53 2.66 2.66 0 011.61.53V9.46a6.33 6.33 0 00-1.61-.21 6.33 6.33 0 000 12.66 6.33 6.33 0 006.33-6.33V8.5a8.27 8.27 0 004.78 1.52v-3.4a4.81 4.81 0 01-1-.03z"/></svg>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Partea dreaptă: Formular de înscriere (Ovasal Style) -->
    <div class="w-full lg:w-[55%] bg-[#111111] px-8 py-16 md:px-16 lg:px-32 flex flex-col justify-center relative">
      <!-- Decorație -->
      <div class="absolute top-10 right-10 flex gap-2 opacity-30">
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-[#cc0000]"></div>
      </div>

      <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Înscrie-te online</h2>
        <p class="text-slate-400 mb-10 text-sm md:text-base">Completați formularul și vă vom contacta cât mai curând posibil.</p>
        
        <form class="space-y-6" action="#" method="POST" onsubmit="event.preventDefault(); alert('Formular de test. Mulțumim!');">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <input type="text" required class="w-full bg-white text-slate-900 px-5 py-4 font-medium outline-none focus:ring-2 focus:ring-[#cc0000] transition-all" placeholder="Nume" />
            </div>
            <div>
              <input type="tel" required class="w-full bg-white text-slate-900 px-5 py-4 font-medium outline-none focus:ring-2 focus:ring-[#cc0000] transition-all" placeholder="Telefon" />
            </div>
          </div>
          
          <div>
            <input type="email" required class="w-full bg-white text-slate-900 px-5 py-4 font-medium outline-none focus:ring-2 focus:ring-[#cc0000] transition-all" placeholder="Email" />
          </div>
          
          <div class="relative">
            <select required class="w-full bg-white text-slate-900 px-5 py-4 font-medium outline-none focus:ring-2 focus:ring-[#cc0000] transition-all appearance-none cursor-pointer">
              <option value="" disabled selected>Sunt interesat de</option>
              <option value="cat_b">Categoria B</option>
              <option value="cat_b1">Categoria B1 / BE</option>
              <option value="cat_c">Categoria C / CE</option>
              <option value="info">Doar informații</option>
            </select>
            <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>
          
          <div>
            <textarea rows="4" class="w-full bg-white text-slate-900 px-5 py-4 font-medium outline-none focus:ring-2 focus:ring-[#cc0000] transition-all resize-none" placeholder="Alte informații/mențiuni"></textarea>
          </div>
          
          <!-- Mock reCAPTCHA -->
          <div class="bg-white inline-flex items-center gap-4 px-4 py-3 rounded-sm border border-slate-200">
            <div class="w-6 h-6 border-2 border-slate-300 rounded-sm"></div>
            <span class="text-sm font-medium text-slate-700">Nu sunt robot</span>
            <div class="flex flex-col items-center ml-8">
              <svg class="w-8 h-8 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
              <span class="text-[0.5rem] text-slate-500">reCAPTCHA</span>
            </div>
          </div>
          
          <div>
            <button type="submit" class="bg-transparent hover:bg-white text-white hover:text-[#111111] border border-[#cc0000] font-bold py-4 px-12 transition-colors uppercase tracking-widest text-sm mt-4">
              TRIMITE
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</MainLayout>
