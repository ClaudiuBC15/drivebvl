  <!-- Scripts -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Form submission and success state logic
      const form = document.getElementById('enrollment-form');
      const formContainer = document.getElementById('form-container');
      const successContainer = document.getElementById('success-container');
      const resetBtn = document.getElementById('reset-form-btn');

      if (form && formContainer && successContainer) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const formData = new FormData(form);
          const email = formData.get('email');
          const originalMessage = formData.get('message') || '';
          
          // Format message to include email on top, as the database leads table does not have an email column
          const message = email ? `Email: ${email}\n\nMesaj:\n${originalMessage}` : originalMessage;

          const payload = {
            name: formData.get('name'),
            phone: formData.get('phone'),
            category: formData.get('category'),
            message: message,
            source: 'website_contact_page'
          };

          try {
            await fetch('/api/leads', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            
            // Switch views on success
            formContainer.classList.add('hidden');
            successContainer.classList.remove('hidden');
            form.reset();
          } catch (err) {
            console.error('Error submitting contact lead:', err);
            // Fallback success view for a good user experience
            formContainer.classList.add('hidden');
            successContainer.classList.remove('hidden');
            form.reset();
          }
        });
      }

      if (resetBtn && formContainer && successContainer) {
        resetBtn.addEventListener('click', () => {
          successContainer.classList.add('hidden');
          formContainer.classList.remove('hidden');
        });
      }

      // 2. FAQ Accordion toggle animation script
      const faqTriggers = document.querySelectorAll('.faq-trigger');
      faqTriggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const item = trigger.closest('.faq-item');
          const content = item.querySelector('.faq-content');
          const icon = item.querySelector('.faq-icon');
          const isOpen = content.classList.contains('grid-rows-[1fr]');
          
          // Close other active FAQ items
          document.querySelectorAll('.faq-item').forEach(otherItem => {
            if (otherItem !== item) {
              otherItem.querySelector('.faq-content').classList.remove('grid-rows-[1fr]');
              otherItem.querySelector('.faq-content').classList.add('grid-rows-[0fr]');
              otherItem.querySelector('.faq-icon').classList.remove('rotate-180');
            }
          });

          // Toggle current FAQ item
          if (isOpen) {
            content.classList.remove('grid-rows-[1fr]');
            content.classList.add('grid-rows-[0fr]');
            icon.classList.remove('rotate-180');
          } else {
            content.classList.remove('grid-rows-[0fr]');
            content.classList.add('grid-rows-[1fr]');
            icon.classList.add('rotate-180');
          }
        });
      });
    });
  </script>
