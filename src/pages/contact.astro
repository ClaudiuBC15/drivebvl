---
import MainLayout from '../layouts/main.astro';
---

<MainLayout 
  title="Contact | Start Drive BVL Suceava"
  description="Contactează echipa Start Drive BVL Suceava. Sună la 0744 420 905 sau trimite-ne un mesaj. Ne găsești pe Strada Mărăști, Nr. 12, Bl. T2, Suceava (în parcarea MPO)."
>
  
  <!-- Hero Section -->
  <section class="relative bg-white pt-28 pb-8 md:pt-36 md:pb-12 overflow-hidden">
    <!-- Grid pattern background decoration -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left side text & buttons -->
      <div class="lg:col-span-7 text-left space-y-6 animate-fade-in-up">
        <div>
          <span class="text-[#cc0000] font-bold text-xs uppercase tracking-wider block mb-2">Contactează-ne</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-4">
            Hai să discutăm <br/>
            <span class="text-[#cc0000]">despre permisul tău</span>
          </h1>
          <p class="text-slate-600 font-light text-base md:text-lg max-w-xl leading-relaxed">
            Ai întrebări despre înscriere, categorii sau documentele necesare? Echipa Start Drive BVL îți răspunde rapid.
          </p>
        </div>
        
        <div class="flex flex-wrap gap-4 pt-2">
          <a 
            href="tel:0744420905" 
            class="inline-flex items-center justify-center gap-2 bg-[#cc0000] hover:bg-red-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg focus:outline-none text-sm cursor-pointer select-none"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Sună acum
          </a>
          <a 
            href="#contact-form-section" 
            class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 font-bold py-3.5 px-6 rounded-xl transition-all duration-200 shadow-sm focus:outline-none text-sm cursor-pointer select-none"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Trimite mesaj
          </a>
        </div>
      </div>
      
      <!-- Right side photo -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay: 0.15s;">
        <div class="relative max-w-sm md:max-w-md w-full">
          <!-- Background decorative shapes -->
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-red-100 rounded-3xl -z-10 blur-xl opacity-60"></div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-slate-100 rounded-full -z-10 blur-2xl opacity-80"></div>
          
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border-[6px] border-white bg-slate-100">
            <img 
              src="/images/contact_student.png" 
              alt="Cursantă Start Drive BVL cu permisul de conducere" 
              class="w-full aspect-[4/5] object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Contact Details Strip -->
  <section class="bg-[#fafafa] py-12 border-y border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Telefon -->
        <a 
          href="tel:0744420905" 
          class="bg-white p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.03)] flex items-center gap-5 hover:border-red-200 transition-all group"
        >
          <div class="w-12 h-12 rounded-xl bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 group-hover:scale-105 transition-transform shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-0.5">Telefon</span>
            <span class="font-extrabold text-slate-800 text-lg group-hover:text-[#cc0000] transition-colors block">0744 420 905</span>
            <span class="text-xs text-slate-500 font-light block mt-0.5">Sună acum pentru detalii</span>
          </div>
        </a>

        <!-- Email -->
        <a 
          href="mailto:contact@startdrivebvl.ro" 
          class="bg-white p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.03)] flex items-center gap-5 hover:border-red-200 transition-all group"
        >
          <div class="w-12 h-12 rounded-xl bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 group-hover:scale-105 transition-transform shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-0.5">Email</span>
            <span class="font-extrabold text-slate-800 text-base md:text-lg group-hover:text-[#cc0000] transition-colors block truncate">contact@startdrivebvl.ro</span>
            <span class="text-xs text-slate-500 font-light block mt-0.5">Îți răspundem în cel mai scurt timp</span>
          </div>
        </a>

        <!-- Locație -->
        <div 
          class="bg-white p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.03)] flex items-center gap-5 shrink-0"
        >
          <div class="w-12 h-12 rounded-xl bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-0.5">Locație</span>
            <span class="font-extrabold text-slate-800 text-lg block">Suceava</span>
            <span class="text-xs text-slate-500 font-light block mt-0.5">Vezi pe hartă locația noastră</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Split Form & Benefits Section -->
  <section id="contact-form-section" class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left side: Send us a message form -->
      <div class="lg:col-span-7">
        <div class="bg-white rounded-3xl border border-slate-100 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.04)] p-8 md:p-10">
          
          <!-- State 1: Contact Form -->
          <div id="form-container" class="transition-all duration-300">
            <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight mb-8">Trimite-ne un mesaj</h2>
            
            <form id="enrollment-form" class="space-y-6" action="#" method="POST">
              <!-- Name Input -->
              <div>
                <label for="name" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Nume complet</label>
                <div class="relative">
                  <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-12 pr-4 py-3.5 text-slate-800 placeholder-slate-400 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none"
                    placeholder="Nume complet"
                  />
                </div>
              </div>

              <!-- Phone Input -->
              <div>
                <label for="phone" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Telefon</label>
                <div class="relative">
                  <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-12 pr-4 py-3.5 text-slate-800 placeholder-slate-400 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none"
                    placeholder="Telefon"
                  />
                </div>
              </div>

              <!-- Email Input -->
              <div>
                <label for="email" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Email</label>
                <div class="relative">
                  <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-12 pr-4 py-3.5 text-slate-800 placeholder-slate-400 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none"
                    placeholder="Email"
                  />
                </div>
              </div>

              <!-- Category Dropdown -->
              <div>
                <label for="category" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Categoria dorită</label>
                <div class="relative">
                  <select
                    id="category"
                    name="category"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-slate-850 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none appearance-none cursor-pointer"
                  >
                    <option value="" disabled selected>Alege categoria...</option>
                    <option value="B">Categoria B</option>
                    <option value="BE">Categoria BE</option>
                    <option value="C">Categoria C</option>
                    <option value="CE">Categoria CE</option>
                    <option value="D">Categoria D</option>
                  </select>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Message Input -->
              <div>
                <label for="message" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Mesajul tău</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-slate-800 placeholder-slate-400 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none resize-none"
                  placeholder="Mesajul tău"
                ></textarea>
              </div>

              <!-- Consent Checkbox -->
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="agreement"
                  name="agreement"
                  required
                  class="mt-1 h-4 w-4 rounded border-slate-350 text-[#cc0000] focus:ring-[#cc0000] cursor-pointer"
                />
                <label for="agreement" class="text-xs text-slate-500 leading-normal select-none cursor-pointer">
                  Sunt de acord cu prelucrarea datelor personale.
                </label>
              </div>

              <!-- Submit Button -->
              <div>
                <button
                  type="submit"
                  class="w-full bg-[#cc0000] hover:bg-red-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-red-500/20 active:scale-[0.99] flex items-center justify-center gap-2 cursor-pointer select-none uppercase tracking-wider text-xs"
                >
                  Trimite solicitarea
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <!-- State 2: Success State (Hidden by default) -->
          <div id="success-container" class="hidden text-center py-12 px-4 transition-all duration-300">
            <div class="w-20 h-20 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center mx-auto mb-6 border border-emerald-100 shadow-sm animate-bounce">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-2xl font-extrabold text-slate-900 tracking-tight mb-3">Solicitare înregistrată!</h3>
            <p class="text-slate-600 max-w-md mx-auto mb-8 leading-relaxed font-light">
              Mulțumim pentru înscriere. Un reprezentant al școlii auto <strong class="text-slate-900">Start Drive BVL</strong> te va contacta telefonic în maxim 24 de ore pentru a stabili detaliile.
            </p>
            <button
              id="reset-form-btn"
              class="inline-flex items-center gap-2 border border-slate-200 hover:border-slate-300 text-slate-650 font-bold py-3 px-6 rounded-xl transition-all duration-200 hover:bg-slate-50 cursor-pointer text-sm"
            >
              Trimite o altă solicitare
            </button>
          </div>

        </div>
      </div>

      <!-- Right side: Benefits and reasons to contact -->
      <div class="lg:col-span-5 flex flex-col justify-between">
        <div class="space-y-8">
          <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">De ce să ne contactezi?</h2>
          
          <ul class="space-y-6">
            <!-- 1. Informații înscriere -->
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full border border-red-200 bg-red-50/50 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 text-base mb-1">Informații despre înscriere</h4>
                <p class="text-slate-500 font-light text-sm leading-relaxed">Te ghidăm pas cu pas în procesul de înscriere.</p>
              </div>
            </li>

            <!-- 2. Programări rapide -->
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full border border-red-200 bg-red-50/50 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 text-base mb-1">Programări rapide</h4>
                <p class="text-slate-500 font-light text-sm leading-relaxed">Stabilim împreună programul potrivit pentru tine.</p>
              </div>
            </li>

            <!-- 3. Documente necesare -->
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full border border-red-200 bg-red-50/50 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 text-base mb-1">Documente necesare</h4>
                <p class="text-slate-500 font-light text-sm leading-relaxed">Îți explicăm exact ce acte ai nevoie.</p>
              </div>
            </li>

            <!-- 4. Detalii categorii -->
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full border border-red-200 bg-red-50/50 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 text-base mb-1">Detalii despre categorii</h4>
                <p class="text-slate-500 font-light text-sm leading-relaxed">Alegi categoria potrivită scopului tău.</p>
              </div>
            </li>

            <!-- 5. Informații costuri -->
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full border border-red-200 bg-red-50/50 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 text-base mb-1">Informații despre costuri</h4>
                <p class="text-slate-500 font-light text-sm leading-relaxed">Prețuri transparente, fără costuri ascunse.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="mt-8">
          <img 
            src="/images/contact_instructor.png" 
            alt="Instructor auto explicând traseul pe tabletă" 
            class="rounded-2xl shadow-md border border-slate-100 w-full object-cover h-[200px] md:h-[240px]"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-slate-50/50 py-16 md:py-24 border-y border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-10 text-center">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-3">Unde ne găsești</h2>
        <p class="text-slate-600 font-light max-w-xl mx-auto text-base">
          Te așteptăm la sediul nostru pentru înscriere și informații complete despre cursuri.
        </p>
      </div>

      <!-- Map Wrapper -->
      <div class="relative w-full rounded-3xl overflow-hidden shadow-lg border border-slate-200/60 bg-white p-2 h-[450px]">
        <iframe
          src="https://www.google.com/maps?q=47.64761027691624,26.252242589241373&z=16&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Start Drive BVL Suceava pe Google Maps"
          class="rounded-2xl"
        ></iframe>

        <!-- Floating Address Card Overlay (visible on desktop/tablet) -->
        <div class="absolute bottom-8 left-8 z-10 bg-white rounded-2xl shadow-2xl border border-slate-100 p-6 max-w-[280px] hidden md:block">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-xl bg-red-50 text-[#cc0000] flex items-center justify-center border border-red-100/50 shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-800 text-sm mb-1">Adresă</h3>
              <p class="text-xs text-slate-500 font-light leading-relaxed mb-4">
                Strada Mărăști, Nr. 12, Bl. T2,<br/>Suceava (pe Mărășești, în parcarea MPO)
              </p>
              <a 
                href="https://www.google.com/maps/search/?api=1&query=47.64761027691624,26.252242589241373" 
                target="_blank" 
