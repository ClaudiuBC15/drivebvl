---
import MainLayout from '../../layouts/main.astro';
import { getDB, queryOne, queryAll, parseJSON } from '../../lib/db';

export const prerender = false;

const { slug } = Astro.params;
const db = getDB(Astro.locals);

// Fetch category from D1
const category = await queryOne<any>(
  db,
  'SELECT * FROM categories WHERE slug = ?',
  [slug]
);

if (!category) {
  return new Response(null, { status: 404, statusText: 'Category Not Found' });
}

// Map slug to category name for FAQs
let faqCategoryName = 'Categoria B';
if (slug === 'c' || slug === 'ce') {
  faqCategoryName = 'Categoria C/CE';
} else if (slug === 'd') {
  faqCategoryName = 'Categoria D';
} else if (slug === 'b1') {
  faqCategoryName = 'Categoria B1';
}

// Fetch relevant FAQs from D1
const faqs = await queryAll<any>(
  db,
  'SELECT * FROM faqs WHERE category = ? ORDER BY sort_order ASC',
  [faqCategoryName]
);

// Parse JSON fields
const descriptions = parseJSON<string[]>(category.description, []);
const whatYouCanDrive = parseJSON<string[]>(category.what_you_can_drive, []);
const conditions = parseJSON<string[]>(category.conditions, []);
const documents = parseJSON<string[]>(category.documents, []);
const testimonials = parseJSON<any[]>(category.testimonials, []);
const graduateImages = parseJSON<string[]>(category.graduate_images, []);

// SEO Tags
const title = category.seo_title || `${category.name} Suceava — Școala de Șoferi Start Drive BVL`;
const description = category.seo_description || `Obține permisul auto ${category.name} în Suceava. Cursuri teoretice și practice cu instructori profesioniști la Start Drive BVL.`;

// Build course Schema.org JSON-LD
const schemaJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Course",
      "@id": `https://startdrivebvl.ro/categoria/${slug}#course`,
      "name": category.name,
      "description": description,
      "provider": {
        "@type": "DrivingSchool",
        "name": "Start Drive BVL",
        "sameAs": "https://startdrivebvl.ro/"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `https://startdrivebvl.ro/categoria/${slug}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Acasă",
          "item": "https://startdrivebvl.ro/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Categorii",
          "item": "https://startdrivebvl.ro/categorii"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": category.name,
          "item": `https://startdrivebvl.ro/categoria/${slug}`
        }
      ]
    }
  ]
};

// Add FAQPage Schema if FAQs are present
if (faqs.length > 0) {
  (schemaJson["@graph"] as any).push({
    "@type": "FAQPage",
    "@id": `https://startdrivebvl.ro/categoria/${slug}#faq`,
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.answer
      }
    }))
  });
}
---

<MainLayout title={title} description={description} ogImage={category.image_url}>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} is:inline />

  <!-- Hero Section -->
  <div class="relative w-full min-h-[450px] bg-[#0a0a0b] overflow-hidden flex flex-col justify-center items-center py-20 px-6">
    <!-- Background Image with Dark Overlay -->
    <div class="absolute inset-0 bg-cover bg-center opacity-25 scale-105" style={`background-image: url('${category.image_url || '/images/cat-b.png'}')`}></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0b]/80 via-[#0a0a0b]/95 to-[#0a0a0b]"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center flex flex-col items-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-red-950/80 text-[#ff3333] border border-red-900/50 mb-6 backdrop-blur-md">
        Școala de Șoferi Suceava
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white tracking-tight uppercase mb-4">
        {category.hero_title || category.name}
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 font-medium tracking-wide mb-8">
        {category.hero_subtitle}
      </p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#inscriere" class="bg-[#cc0000] hover:bg-red-700 text-white font-bold py-3.5 px-8 rounded-xl transition-all duration-200 shadow-lg shadow-red-900/20 active:scale-[0.98] uppercase tracking-wider text-xs">
          Înscrie-te acum
        </a>
        <a href="tel:+40744420905" class="bg-white/10 hover:bg-white/20 text-white font-bold py-3.5 px-8 rounded-xl transition-all duration-200 border border-white/10 backdrop-blur-md active:scale-[0.98] uppercase tracking-wider text-xs">
          Suna-ne direct
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Stânga: Detalii Curs, Acte, Condiții -->
      <div class="lg:col-span-7 space-y-12">
        
        <!-- Descriere generală -->
        <div class="space-y-6">
          <h2 class="text-3xl font-extrabold text-[#0a0a0b] tracking-tight">Despre curs</h2>
          <div class="h-1 w-12 bg-[#cc0000] rounded-full"></div>
          <div class="space-y-4 text-slate-600 font-light leading-relaxed text-base md:text-lg">
            {descriptions.map((desc) => (
              <p>{desc}</p>
            ))}
          </div>
        </div>

        <!-- Ce poți conduce -->
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200/50">
          <h3 class="text-xl font-bold text-[#0a0a0b] mb-4 flex items-center gap-2.5">
            <svg class="w-6 h-6 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
            </svg>
            Ce poți conduce cu permisul {category.id}:
          </h3>
          <ul class="space-y-3">
            {whatYouCanDrive.map((item) => (
              <li class="flex items-start gap-3 text-slate-700 font-light">
                <span class="text-[#cc0000] text-lg select-none">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Condiții de Înscriere -->
        <div class="space-y-6">
          <h3 class="text-2xl font-bold text-[#0a0a0b] tracking-tight">Condiții de înscriere</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {conditions.map((condition) => (
              <div class="flex items-center gap-3 p-4 bg-white border border-slate-100 rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.01)]">
                <div class="w-6 h-6 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm font-medium text-slate-700">{condition}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Acte necesare -->
        <div class="space-y-6">
          <h3 class="text-2xl font-bold text-[#0a0a0b] tracking-tight">Acte necesare la dosar</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {documents.map((doc, idx) => (
              <div class="flex gap-4 p-5 bg-white border border-slate-100 rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.01)]">
                <span class="text-2xl font-bold text-red-100/80 leading-none select-none">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span class="text-sm text-slate-600 font-light leading-relaxed">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Structură și Durată -->
        <div class="space-y-6">
          <h3 class="text-2xl font-bold text-[#0a0a0b] tracking-tight">Durată și Structură Curs</h3>
          <div class="relative pl-8 border-l-2 border-red-500/20 space-y-8 py-2">
            <!-- Timeline Item 1 -->
            <div class="relative">
              <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-red-600 border-4 border-white flex items-center justify-center"></div>
              <h4 class="text-base font-bold text-[#0a0a0b] mb-1">Înscriere & Pregătire Dosar</h4>
              <p class="text-sm text-slate-600 font-light leading-relaxed">Îți pregătim dosarul și te programăm la examenul medical și psihologic în doar câteva zile.</p>
            </div>
            <!-- Timeline Item 2 -->
            <div class="relative">
              <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-red-600 border-4 border-white flex items-center justify-center"></div>
              <h4 class="text-base font-bold text-[#0a0a0b] mb-1">Pregătire Teoretică (Legislație)</h4>
              <p class="text-sm text-slate-600 font-light leading-relaxed">Cursuri interactive de legislație auto în sala noastră modernă, cu profesori dedicați.</p>
            </div>
            <!-- Timeline Item 3 -->
            <div class="relative">
              <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-[#0a0a0b] border-4 border-white flex items-center justify-center"></div>
              <h4 class="text-base font-bold text-[#0a0a0b] mb-1">Instruire Practică</h4>
              <p class="text-sm text-slate-600 font-light leading-relaxed">
                {category.duration_info || 'Orele de conducere practică alături de instructorul ales, pe autoturisme moderne.'}
              </p>
            </div>
          </div>
        </div>

        <!-- Notă Informare -->
        {category.info_note && (
          <div class="bg-red-50 border border-red-100 rounded-2xl p-6 flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#cc0000]/10 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <p class="text-slate-700 font-medium text-sm md:text-base leading-relaxed">
              {category.info_note}
            </p>
          </div>
        )}

        <!-- Absolvenți Reușiți -->
        {graduateImages.length > 0 && (
          <div class="space-y-6 pt-6">
            <div class="flex flex-col gap-2">
              <h2 class="text-3xl font-extrabold text-[#0a0a0b] tracking-tight">Absolvenți care au reușit la {category.name}</h2>
              <div class="h-1 w-12 bg-[#cc0000] rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {graduateImages.map((imgUrl, i) => (
                <a 
                  href={imgUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="group relative aspect-[4/3] rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 bg-slate-100 border border-slate-200/40 block"
                >
                  <img
                    src={imgUrl}
                    alt={`Absolvent reușit ${category.name}`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <span class="text-white text-xs font-bold bg-[#cc0000] px-3.5 py-1.5 rounded-full shadow-md flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/></svg>
                      Mărește
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Testimoniale Categorie -->
        {testimonials.length > 0 && (
          <div class="space-y-6 pt-6">
            <h3 class="text-2xl font-bold text-[#0a0a0b] tracking-tight">Ce spun cursanții noștri</h3>
            <div class="grid grid-cols-1 gap-6">
              {testimonials.map((t) => (
                <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm">
                  <div class="flex items-center gap-1 text-amber-500 mb-3">
                    {Array.from({ length: t.rating || 5 }).map(() => (
                      <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                  <p class="text-slate-600 italic font-light mb-4">"{t.text}"</p>
                  <span class="block text-sm font-bold text-[#0a0a0b]">— {t.name}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- FAQ specific categoriei -->
        {faqs.length > 0 && (
          <div class="space-y-6 pt-6">
            <h3 class="text-2xl font-bold text-[#0a0a0b] tracking-tight">Întrebări frecvente {category.name}</h3>
            <div class="space-y-4">
              {faqs.map((faq, idx) => (
                <div class="border border-slate-200/60 rounded-xl overflow-hidden bg-white">
                  <button 
                    class="faq-toggle w-full text-left px-6 py-4 font-bold text-[#0a0a0b] hover:text-[#cc0000] flex justify-between items-center transition-colors focus:outline-none"
                    aria-expanded="false"
                    data-target={`faq-content-${idx}`}
                  >
                    <span>{faq.question}</span>
                    <svg class="w-5 h-5 text-slate-400 transform transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div id={`faq-content-${idx}`} class="faq-content hidden px-6 pb-4 text-slate-600 font-light text-sm leading-relaxed border-t border-slate-50 pt-3">
                    {faq.answer}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

      </div>

      <!-- Dreapta: Card Preț & Formular de Înscriere -->
      <div id="inscriere" class="lg:col-span-5 space-y-8 lg:sticky lg:top-8 self-start">
        
        <!-- Premium Price / Contact Card -->
        <div class="bg-gradient-to-br from-[#0a0a0b] to-[#1a1a1c] text-white rounded-2xl p-8 border border-white/10 shadow-xl relative overflow-hidden">
          <div class="absolute -right-16 -top-16 w-36 h-36 bg-[#cc0000]/10 rounded-full blur-3xl"></div>
          
          <span class="text-xs font-bold uppercase tracking-widest text-[#ff3333] mb-1 block">Ofertă Specială</span>
          <h3 class="text-3xl font-black mb-4">Tarife Cursuri</h3>
          <p class="text-slate-400 font-light text-sm leading-relaxed mb-6">
            Prețurile noastre sunt competitive și transparente, adaptate în funcție de program și opțiunea de plată în rate.
          </p>
          
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center mb-6">
            <span class="text-sm font-semibold text-slate-300 block mb-1">Preț curs {category.name}</span>
            <span class="text-2xl sm:text-3xl font-extrabold text-white block">Contactează-ne pentru prețuri</span>
            <span class="text-xs text-slate-400 block mt-2">Plată în rate • Fără dobândă</span>
          </div>

          <div class="space-y-4">
            <a href="tel:+40744420905" class="flex items-center justify-center gap-3 bg-[#cc0000] hover:bg-red-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-200 text-center uppercase tracking-wider text-xs">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 00.94.725V17a2 2 0 01-2 2H9C4.03 19 0 14.97 0 10V5z" />
              </svg>
              Suna acum: 0744 420 905
            </a>
          </div>
        </div>

        <!-- Enrollment Form Card -->
        <div class="bg-white rounded-2xl border border-slate-200/50 p-8 shadow-[0_8px_30px_rgb(0,0,0,0.02)]">
          <div id="form-container" class="transition-all duration-300">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-50 text-[#cc0000] border border-red-100/50 mb-4">
              Înscriere Rapidă
            </span>
            <h3 class="text-2xl font-extrabold text-[#0a0a0b] tracking-tight mb-6">Solicită să fii contactat</h3>
            
            <form id="enrollment-form" class="space-y-5" action="#" method="POST">
              <div>
                <label for="name" class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Nume complet</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full bg-slate-50/50 border border-slate-200/80 rounded-xl px-4 py-3 text-slate-800 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-sm"
                  placeholder="Ex: Popescu Ion"
                />
              </div>

              <div>
                <label for="phone" class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Telefon</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full bg-slate-50/50 border border-slate-200/80 rounded-xl px-4 py-3 text-slate-800 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-sm"
                  placeholder="Ex: 0744 123 456"
                />
              </div>

              <div>
                <label for="category" class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Categoria dorită</label>
                <div class="relative">
                  <select
                    id="category"
                    name="category"
                    required
                    class="w-full bg-slate-50/50 border border-slate-200/80 rounded-xl px-4 py-3 text-slate-800 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none appearance-none cursor-pointer text-sm"
                  >
                    <option value="B1" selected={category.id === 'B1'}>Categoria B1</option>
                    <option value="B" selected={category.id === 'B'}>Categoria B</option>
                    <option value="BE" selected={category.id === 'BE'}>Categoria BE</option>
                    <option value="C" selected={category.id === 'C'}>Categoria C</option>
                    <option value="CE" selected={category.id === 'CE'}>Categoria CE</option>
                    <option value="D" selected={category.id === 'D'}>Categoria D</option>
                  </select>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
              </div>

              <div>
                <label for="message" class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Mesaj opțional</label>
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  class="w-full bg-slate-50/50 border border-slate-200/80 rounded-xl px-4 py-3 text-slate-800 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-sm resize-none"
                  placeholder="Dacă dorești să ne transmiți detalii suplimentare..."
                ></textarea>
              </div>

              <div>
                <button
                  type="submit"
                  class="w-full bg-[#cc0000] hover:bg-red-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-red-500/20 active:scale-[0.99] text-center uppercase tracking-wider text-xs cursor-pointer select-none"
                >
                  Solicită să fii contactat
                </button>
              </div>
            </form>

            <!-- Badges -->
            <div class="mt-6 pt-5 border-t border-slate-100 flex flex-col gap-2.5 text-xs font-semibold text-slate-500">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>răspundem în maxim 24h</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>program flexibil</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>instructori acreditați</span>
              </div>
            </div>
          </div>

          <!-- Success State -->
          <div id="success-container" class="hidden text-center py-8 px-2 transition-all duration-300">
            <div class="w-16 h-16 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center mx-auto mb-5 border border-emerald-100 shadow-sm">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h4 class="text-xl font-extrabold text-[#0a0a0b] tracking-tight mb-2">Cerere înregistrată!</h4>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 font-light">
              Mulțumim! Te vom contacta în cel mai scurt timp (maxim 24 ore) pentru detalii.
            </p>
            <button
              id="reset-form-btn"
              class="inline-flex items-center gap-1.5 border border-slate-200 hover:border-slate-300 text-slate-600 font-bold py-2.5 px-5 rounded-xl transition-all duration-200 hover:bg-slate-50 cursor-pointer text-xs"
            >
              Trimite o altă cerere
            </button>
          </div>
        </div>

      </div>

    </div>
  </div>

  <!-- FAQ script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Toggle FAQ items
      const toggles = document.querySelectorAll('.faq-toggle');
      toggles.forEach(toggle => {
        toggle.addEventListener('click', () => {
          const targetId = toggle.getAttribute('data-target');
          const content = document.getElementById(targetId);
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          
          // Toggle icon rotation
          const icon = toggle.querySelector('svg');
          if (icon) {
            if (!expanded) {
              icon.classList.add('rotate-180');
            } else {
              icon.classList.remove('rotate-180');
            }
          }

          // Toggle content visibility
          if (content) {
            if (!expanded) {
              content.classList.remove('hidden');
            } else {
              content.classList.add('hidden');
            }
          }

          toggle.setAttribute('aria-expanded', !expanded);
        });
      });

      // Handle Enrollment Form
      const form = document.getElementById('enrollment-form');
      const formContainer = document.getElementById('form-container');
      const successContainer = document.getElementById('success-container');
      const resetBtn = document.getElementById('reset-form-btn');

      if (form && formContainer && successContainer) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const formData = new FormData(form);
          const payload = {
            name: formData.get('name'),
            phone: formData.get('phone'),
            category: formData.get('category'),
            message: formData.get('message') || '',
            source: 'website_category_page'
          };

          try {
            // Save lead in background if API is ready
            const response = await fetch('/api/leads', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            
            // Switch view regardless of response for smooth UX
            formContainer.classList.add('hidden');
            successContainer.classList.remove('hidden');
            form.reset();
          } catch (err) {
            console.error('Error submitting lead:', err);
            // Fallback: switch view anyway so the user doesn't get stuck
            formContainer.classList.add('hidden');
            successContainer.classList.remove('hidden');
            form.reset();
          }
        });
      }

      if (resetBtn && formContainer && successContainer) {
        resetBtn.addEventListener('click', () => {
          successContainer.classList.add('hidden');
          formContainer.classList.remove('hidden');
        });
      }
    });
  </script>
</MainLayout>
