---
import MainLayout from '../../../layouts/main.astro';
import { getDB, queryAll } from '../../../lib/db';

export const prerender = false;

const { cat } = Astro.params;
const db = getDB(Astro.locals);

// Capitalize category name for display
const formattedCat = cat ? cat.toUpperCase() : '';

// Fetch filtered articles
const articles = await queryAll<any>(
  db,
  "SELECT * FROM articles WHERE status = 'published' AND UPPER(category) = ? ORDER BY created_at DESC",
  [formattedCat]
);

// Fetch recent articles for the sidebar
const recentArticles = await queryAll<any>(
  db,
  "SELECT * FROM articles WHERE status = 'published' ORDER BY created_at DESC LIMIT 4"
);

// Fetch other categories
const categoryRows = await queryAll<any>(
  db,
  "SELECT DISTINCT category FROM articles WHERE status = 'published' AND category IS NOT NULL AND category != ''"
);
const categories = ['Toate', ...categoryRows.map(r => r.category)];

// Date formatting helper
function formatDate(dateStr: string) {
  if (!dateStr) return '';
  try {
    const cleanStr = dateStr.includes(' ') && !dateStr.includes('T') ? dateStr.replace(' ', 'T') : dateStr;
    const date = new Date(cleanStr);
    if (isNaN(date.getTime())) return dateStr;
    return date.toLocaleDateString('ro-RO', { day: '2-digit', month: 'short', year: 'numeric' });
  } catch {
    return dateStr;
  }
}
---

<MainLayout 
  title={`Articole Categorie ${formattedCat} | Blog Start Drive BVL`} 
  description={`Citește articole și sfaturi utile din categoria ${formattedCat} de la Școala de Șoferi Start Drive BVL Suceava.`}
>
  <!-- Hero Section -->
  <div class="relative w-full h-[320px] bg-[#0a0a0b] overflow-hidden flex flex-col justify-center items-center px-6">
    <div class="absolute inset-0 bg-[url('https://i.imgur.com/SsZQl1w.jpeg')] bg-cover bg-center opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0b]/80 to-[#0a0a0b]"></div>
    
    <div class="relative z-10 text-center flex flex-col items-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-950/80 text-[#ff3333] border border-red-900/50 mb-6">
        Categorie Blog
      </span>
      <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight uppercase mb-4">{formattedCat}</h1>
      <div class="flex items-center gap-2 text-slate-400 font-bold text-xs tracking-widest uppercase">
        <a href="/" class="hover:text-white transition-colors">Acasă</a>
        <span>&gt;</span>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <span>&gt;</span>
        <span class="text-[#cc0000]">{formattedCat}</span>
      </div>
    </div>
  </div>

  <div class="bg-[#fafafa] min-h-screen py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Stânga: Articole -->
        <main class="lg:col-span-8 space-y-12">
          
          <!-- Category Tabs on top -->
          <div class="flex flex-wrap gap-2.5 pb-2 overflow-x-auto no-scrollbar border-b border-slate-100">
            {categories.map((c) => {
              const isActive = (c.toLowerCase() === formattedCat.toLowerCase());
              const targetUrl = c === 'Toate' ? '/blog' : `/blog/categorie/${c.toLowerCase()}`;
              return (
                <a
                  href={targetUrl}
                  class={`px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider transition-all duration-200 border ${
                    isActive
                      ? 'bg-[#cc0000] border-[#cc0000] text-white shadow-sm shadow-red-900/10'
                      : 'bg-white border-slate-200 text-slate-600 hover:border-slate-300 hover:text-slate-800'
                  }`}
                >
                  {c}
                </a>
              );
            })}
          </div>

          <!-- Articles List -->
          {articles.length > 0 ? (
            <div class="space-y-10">
              {articles.map((article) => (
                <article class="bg-white rounded-2xl border border-slate-200/50 shadow-[0_4px_20px_rgba(0,0,0,0.01)] overflow-hidden group hover:shadow-[0_8px_30px_rgba(0,0,0,0.03)] transition-all duration-300 flex flex-col md:flex-row">
                  
                  <!-- Image Container -->
                  <a href={`/blog/${article.slug}`} class="block relative w-full md:w-[35%] aspect-[16/9] md:aspect-auto min-h-[220px] overflow-hidden bg-slate-100 shrink-0">
                    <img 
                      src={article.image_url || '/images/cat-b.png'} 
                      alt={article.title} 
                      class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
                      loading="lazy"
                    />
                    <div class="absolute top-4 left-4 bg-[#cc0000] text-white text-[10px] font-bold px-3 py-1 tracking-wider uppercase rounded-md shadow-sm">
                      {article.category}
                    </div>
                  </a>

                  <!-- Content Container -->
                  <div class="p-6 md:p-8 flex flex-col justify-between flex-grow">
                    <div>
                      <div class="flex items-center gap-4 text-xs text-slate-400 font-medium mb-3">
                        <span class="flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                          {formatDate(article.created_at)}
                        </span>
                        <span class="flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                          </svg>
                          {article.author}
                        </span>
                      </div>
                      
                      <a href={`/blog/${article.slug}`} class="block group-hover:text-[#cc0000] transition-colors">
                        <h2 class="text-xl md:text-2xl font-extrabold text-[#0a0a0b] tracking-tight leading-snug mb-3">
                          {article.title}
                        </h2>
                      </a>

                      <p class="text-slate-500 font-light text-sm md:text-base leading-relaxed line-clamp-3 mb-6">
                        {article.excerpt}
                      </p>
                    </div>

                    <a href={`/blog/${article.slug}`} class="inline-flex items-center gap-1.5 text-xs font-bold text-[#cc0000] hover:text-red-700 transition-colors uppercase tracking-wider">
                      Citește articolul
                      <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>

                </article>
              ))}
            </div>
          ) : (
            <div class="text-center py-20 bg-white border border-slate-200/60 rounded-3xl">
              <div class="w-16 h-16 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-slate-800 mb-1">Niciun articol în această categorie</h3>
              <p class="text-slate-500 font-light text-sm max-w-sm mx-auto px-4">
                Nu s-a găsit niciun articol publicat sub categoria {formattedCat} momentan.
              </p>
              <a href="/blog" class="inline-flex items-center gap-1.5 text-xs font-bold text-[#cc0000] uppercase tracking-wider mt-6">
                Mergi la toate articolele
              </a>
            </div>
          )}

        </main>

        <!-- Dreapta: Sidebar -->
        <aside class="lg:col-span-4 space-y-10">
          
          <!-- Căutare -->
          <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-[0_2px_8px_rgba(0,0,0,0.01)]">
            <h3 class="text-base font-bold text-[#0a0a0b] uppercase tracking-wider mb-4">Caută pe blog</h3>
            <form action="/blog" method="GET" class="relative">
              <input 
                type="text" 
                name="search"
                placeholder="Introdu cuvinte cheie..."
                class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-4 pr-10 py-3 text-slate-800 placeholder-slate-400 focus:bg-white focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/5 transition-all outline-none text-sm font-light"
              />
              <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </button>
            </form>
          </div>

          <!-- Articole Recente -->
          <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-[0_2px_8px_rgba(0,0,0,0.01)]">
            <h3 class="text-base font-bold text-[#0a0a0b] uppercase tracking-wider mb-6">Articole Recente</h3>
            <div class="space-y-5">
              {recentArticles.map((art) => (
                <a href={`/blog/${art.slug}`} class="flex gap-4 group">
                  <div class="w-16 h-16 rounded-lg overflow-hidden shrink-0 bg-slate-100">
                    <img 
                      src={art.image_url || '/images/cat-b.png'} 
                      alt={art.title} 
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-[#0a0a0b] group-hover:text-[#cc0000] leading-snug line-clamp-2 transition-colors">
                      {art.title}
                    </h4>
                    <span class="text-[11px] text-slate-400 font-medium block mt-1">
                      {formatDate(art.created_at)}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>

        </aside>
        
      </div>
    </div>
  </div>
</MainLayout>
