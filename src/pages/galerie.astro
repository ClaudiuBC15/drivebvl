---
import MainLayout from '../layouts/main.astro';
import { getDB, queryAll } from '../lib/db';

export const prerender = false;

const db = getDB(Astro.locals);
let galleryItems: any[] = [];

try {
  galleryItems = await queryAll<any>(db, 'SELECT * FROM gallery_images ORDER BY sort_order ASC, created_at DESC');
} catch (err) {
  console.error('Error fetching gallery items:', err);
}

// Fallback items if database is empty
const fallbackItems = [
  { id: 1, image_url: 'https://i.imgur.com/a7H0dcY.jpeg', album: 'cursanti', caption: 'Cursantă admisă la examen', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 2, image_url: 'https://i.imgur.com/y7rAASu.jpeg', album: 'masini', caption: 'Dacia Logan Flotă Auto', media_type: 'image', video_url: null, layout_size: 'wide' },
  { id: 3, image_url: 'https://i.imgur.com/TNY8kty.jpeg', album: 'instructori', caption: 'Pregătire la sală cu instructor', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 4, image_url: 'https://i.imgur.com/GZrbulS.jpeg', album: 'evenimente', caption: 'Predare cheie cursant fericit', media_type: 'image', video_url: null, layout_size: 'tall' },
  { id: 5, image_url: 'https://i.imgur.com/lL14tcK.jpeg', album: 'examene', caption: 'Admisă din prima încercare', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 6, image_url: 'https://i.imgur.com/5FAerI9.jpeg', album: 'altele', caption: 'Ore practice poligon', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 7, image_url: 'https://i.imgur.com/ZPt5cxE.jpeg', album: 'cursanti', caption: 'Zâmbetul de după promovare', media_type: 'image', video_url: null, layout_size: 'large' },
  { id: 8, image_url: 'https://i.imgur.com/cJRWu2Y.jpeg', album: 'cursanti', caption: 'Carnet obținut cu brio', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 9, image_url: 'https://i.imgur.com/DZ3eM1s.jpeg', album: 'masini', caption: 'Mașini pregătite de traseu', media_type: 'image', video_url: null, layout_size: 'normal' },
  { id: 10, image_url: 'https://i.imgur.com/JePRqEz.jpeg', album: 'evenimente', caption: 'Video Prezentare Start Drive BVL', media_type: 'video', video_url: 'https://www.youtube.com/watch?v=dQw4w9WgXcQ', layout_size: 'wide' }
];

const itemsToDisplay = galleryItems.length > 0 ? galleryItems : fallbackItems;
---

<MainLayout 
  title="Galerie Media | Start Drive BVL Suceava"
  description="Descoperă galeria noastră media cu absolvenții fericiți, flota de mașini, instructorii noștri și momente de succes de la examenele auto din Suceava."
>
  <!-- Hero Section with Background image fade-in -->
  <section class="relative bg-white pt-24 pb-12 md:pt-32 md:pb-16 overflow-hidden border-b border-slate-100">
    <div class="absolute inset-y-0 right-0 w-full lg:w-1/2 opacity-35 lg:opacity-75 pointer-events-none">
      <div class="absolute inset-0 bg-[url('https://i.imgur.com/y7rAASu.jpeg')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-slate-400 font-bold text-xs tracking-wider uppercase mb-6">
        <a href="/" class="hover:text-[#cc0000] transition-colors">Acasă</a>
        <span>&gt;</span>
        <span class="text-slate-500">Galerie</span>
      </nav>

      <div class="max-w-2xl text-left space-y-4">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight leading-[1.08]">
          Momente care <br class="hidden sm:inline"/>
          <span class="text-[#cc0000]">ne inspiră</span>
        </h1>
        <p class="text-slate-500 font-normal text-sm md:text-base leading-relaxed max-w-xl">
          Descoperă imagini din activitatea noastră zilnică: cursanți, instructori, mașini și momente de succes.
        </p>
      </div>

      <!-- Filter Buttons Tabs -->
      <div class="flex flex-wrap gap-2.5 mt-10">
        <button data-filter="all" class="filter-btn bg-[#cc0000] text-white border border-[#cc0000] px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Toate
        </button>
        <button data-filter="cursanti" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Cursanți
        </button>
        <button data-filter="instructori" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Instructori
        </button>
        <button data-filter="masini" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Mașini
        </button>
        <button data-filter="evenimente" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Evenimente
        </button>
        <button data-filter="examene" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Examene
        </button>
        <button data-filter="altele" class="filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm">
          Altele
        </button>
      </div>
    </div>
  </section>

  <!-- Grid Section -->
  <section class="bg-[#f8fafc]/50 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-[220px]">
        {itemsToDisplay.map((item, index) => {
          // Determine grid col/row span based on size parameter
          let gridClasses = "col-span-1 row-span-1";
          if (item.layout_size === 'wide') {
            gridClasses = "col-span-1 sm:col-span-2 row-span-1";
          } else if (item.layout_size === 'tall') {
            gridClasses = "col-span-1 row-span-2";
          } else if (item.layout_size === 'large') {
            gridClasses = "col-span-1 sm:col-span-2 row-span-2";
          }

          return (
            <div 
              data-album={item.album}
              data-index={index}
              data-type={item.media_type}
              data-video={item.video_url || ''}
              class={`gallery-item relative overflow-hidden rounded-[24px] shadow-sm border border-slate-100/50 bg-white group cursor-pointer transition-all duration-300 hover:shadow-lg hover:-translate-y-1 ${gridClasses}`}
            >
              <!-- Media Image Cover -->
              <img 
                src={item.image_url} 
                alt={item.caption} 
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                style={`object-position: ${item.object_position || 'center'}`}
                loading="lazy"
              />

              <!-- Dark Overlay with caption on Hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-350 flex flex-col justify-end p-6">
                <!-- Video badge or default tag -->
                <div class="flex items-center justify-between mb-2">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[9px] font-bold bg-[#cc0000] text-white uppercase tracking-wider">
                    {item.album}
                  </span>
                  {item.media_type === 'video' && (
                    <span class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm border border-white/40 flex items-center justify-center text-white">
                      <svg class="w-4.5 h-4.5 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </span>
                  )}
                </div>
                {item.caption && item.caption.trim() !== '' && (
                  <h3 class="text-white font-bold text-sm tracking-tight">{item.caption}</h3>
                )}
              </div>

              <!-- Static Play overlay for Video in standard state -->
              {item.media_type === 'video' && (
                <div class="absolute top-4 left-4 bg-emerald-500 text-white px-2 py-0.5 rounded-md text-[9px] font-bold uppercase tracking-wider flex items-center gap-1 shadow-sm">
                  <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  Video
                </div>
              )}
            </div>
          );
        })}
      </div>

      <!-- No items match filter container -->
      <div id="no-items-message" class="hidden text-center py-20 bg-white border border-slate-100 rounded-3xl mt-6">
        <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <p class="text-slate-500 font-bold">Niciun element în această categorie.</p>
        <p class="text-slate-400 text-xs mt-1">Poți adăuga imagini și clipuri din panoul de administrare.</p>
      </div>
    </div>
  </section>

  <!-- CTA Bottom Section -->
  <section class="relative bg-gradient-to-r from-[#cc0000] to-red-800 py-16 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.08),transparent_50%)]"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
      <div class="space-y-2">
        <h2 class="text-3xl font-extrabold text-white tracking-tight" style="font-family:'Plus Jakarta Sans',sans-serif">
          Vrei să faci parte din povestea noastră?
        </h2>
        <p class="text-white/85 text-sm md:text-base font-normal">
          Înscrie-te acum și hai să scriem împreună următorul capitol.
        </p>
      </div>
      <a 
        href="/inscrieri" 
        class="inline-flex items-center justify-center gap-2 bg-white text-[#cc0000] hover:bg-slate-50 font-bold px-8 py-3.5 rounded-full transition-all hover:scale-105 shadow-lg text-sm select-none cursor-pointer uppercase tracking-wider shrink-0"
      >
        Înscrie-te acum &rarr;
      </a>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="gallery-lightbox" class="fixed inset-0 z-[200] bg-black/95 hidden items-center justify-center opacity-0 transition-opacity duration-300">
    <!-- Close -->
    <button id="close-gallery-lightbox" class="absolute top-6 right-6 text-white hover:text-[#cc0000] transition-colors p-2 bg-white/5 hover:bg-white/10 rounded-full border border-white/10 z-[210] cursor-pointer" aria-label="Închide">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <!-- Nav buttons -->
    <button id="prev-gallery-lightbox" class="absolute left-6 top-1/2 -translate-y-1/2 text-white hover:text-[#cc0000] transition-colors p-3 bg-white/5 hover:bg-white/10 rounded-full border border-white/10 z-[210] cursor-pointer" aria-label="Precedent">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="next-gallery-lightbox" class="absolute right-6 top-1/2 -translate-y-1/2 text-white hover:text-[#cc0000] transition-colors p-3 bg-white/5 hover:bg-white/10 rounded-full border border-white/10 z-[210] cursor-pointer" aria-label="Următorul">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>

    <!-- Container for active media -->
    <div class="relative w-[90%] max-w-4xl max-h-[85vh] flex items-center justify-center">
      <!-- Image Render -->
      <img id="lightbox-image-render" src="" alt="Zoomed Media" class="max-w-full max-h-[80vh] object-contain rounded-2xl hidden shadow-2xl border border-white/15" />

      <!-- Video Render Container -->
      <div id="lightbox-video-container" class="w-full aspect-video max-w-3xl hidden rounded-2xl overflow-hidden shadow-2xl border border-white/15">
        <!-- Will inject HTML5 or Youtube player here -->
      </div>

      <!-- Caption -->
      <div class="absolute bottom-[-48px] left-1/2 -translate-x-1/2 text-center text-white/90 text-sm font-semibold tracking-wide w-full" id="lightbox-caption-text"></div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // === Filter logic ===
      const filterButtons = document.querySelectorAll('.filter-btn');
      const galleryItems = document.querySelectorAll('.gallery-item');
      const noItemsMsg = document.getElementById('no-items-message');

      function updateGrid() {
        const activeBtn = document.querySelector('.filter-btn.bg-\\[\\#cc0000\\]');
        const filter = activeBtn ? activeBtn.dataset.filter : 'all';
        let visibleCount = 0;

        galleryItems.forEach(item => {
          const isMatching = filter === 'all' || item.dataset.album === filter;
          if (isMatching) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          noItemsMsg.classList.remove('hidden');
        } else {
          noItemsMsg.classList.add('hidden');
        }
      }

      filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Reset all buttons
          filterButtons.forEach(b => {
            b.className = 'filter-btn bg-white text-slate-650 border border-slate-200 hover:border-slate-350 hover:text-slate-800 px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm';
          });
          // Set active button
          btn.className = 'filter-btn bg-[#cc0000] text-white border border-[#cc0000] px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider cursor-pointer transition-all shadow-sm';
          updateGrid();
        });
      });

      // === Lightbox logic ===
      const lightbox = document.getElementById('gallery-lightbox');
      const closeBtn = document.getElementById('close-gallery-lightbox');
      const prevBtn = document.getElementById('prev-gallery-lightbox');
      const nextBtn = document.getElementById('next-gallery-lightbox');
      
      const imgRender = document.getElementById('lightbox-image-render');
      const videoContainer = document.getElementById('lightbox-video-container');
      const captionText = document.getElementById('lightbox-caption-text');

      let currentActiveIndex = 0;
      let activeFilteredItems = [];

      function parseYoutubeId(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length === 11) ? match[2] : null;
      }

      function showMedia(index) {
        if (index < 0 || index >= activeFilteredItems.length) return;
        currentActiveIndex = index;
        const item = activeFilteredItems[index];

        // Reset elements
        imgRender.classList.add('hidden');
        videoContainer.classList.add('hidden');
        videoContainer.innerHTML = '';
        captionText.textContent = item.querySelector('h3') ? item.querySelector('h3').textContent : '';

        if (item.dataset.type === 'video') {
          const videoUrl = item.dataset.video;
          const youtubeId = parseYoutubeId(videoUrl);

          if (youtubeId) {
            videoContainer.innerHTML = `<iframe src="https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0" class="w-full h-full" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
          } else {
            videoContainer.innerHTML = `<video src="${videoUrl}" autoplay controls class="w-full h-full object-contain bg-black"></video>`;
          }
          videoContainer.classList.remove('hidden');
        } else {
          const imgSrc = item.querySelector('img').src;
          imgRender.src = imgSrc;
          imgRender.classList.remove('hidden');
        }
      }

      function openLightbox(item) {
        // Collect current filtered visible items in order
        const activeBtn = document.querySelector('.filter-btn.bg-\\[\\#cc0000\\]');
        const filter = activeBtn ? activeBtn.dataset.filter : 'all';

        activeFilteredItems = Array.from(galleryItems).filter(el => filter === 'all' || el.dataset.album === filter);
        const relativeIndex = activeFilteredItems.indexOf(item);

        if (relativeIndex !== -1) {
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
          setTimeout(() => {
            lightbox.classList.remove('opacity-0');
            lightbox.classList.add('opacity-100');
          }, 10);

          showMedia(relativeIndex);
        }
      }

      function closeLightbox() {
        lightbox.classList.remove('opacity-100');
        lightbox.classList.add('opacity-0');
        setTimeout(() => {
          lightbox.classList.remove('flex');
          lightbox.classList.add('hidden');
          videoContainer.innerHTML = ''; // Stop video playback
        }, 300);
      }

      galleryItems.forEach(item => {
        item.addEventListener('click', () => openLightbox(item));
      });

      closeBtn.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      prevBtn.addEventListener('click', () => {
        if (currentActiveIndex > 0) showMedia(currentActiveIndex - 1);
      });

      nextBtn.addEventListener('click', () => {
        if (currentActiveIndex < activeFilteredItems.length - 1) showMedia(currentActiveIndex + 1);
      });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft' && currentActiveIndex > 0) showMedia(currentActiveIndex - 1);
        if (e.key === 'ArrowRight' && currentActiveIndex < activeFilteredItems.length - 1) showMedia(currentActiveIndex + 1);
      });

      // Run initial load setup
      updateGrid();
    });
  </script>
</MainLayout>
