---
import MainLayout from '../layouts/main.astro';
import { getDB, queryAll, parseJSON } from '../lib/db';

const db = getDB(Astro.locals);
const categoriesFromDb = await queryAll<any>(db, 'SELECT * FROM categories ORDER BY sort_order ASC');

const categories = categoriesFromDb.map(cat => ({
  id: cat.id,
  name: cat.name,
  slug: cat.slug,
  image: cat.image_url,
  desc: parseJSON<string[]>(cat.description, []),
  conditions: parseJSON<string[]>(cat.conditions, []),
  info: cat.info_note || cat.duration_info || ''
}));
---

<MainLayout 
  title="Categorii Permis Auto | Start Drive BVL Suceava"
  description="Descoperă categoriile de permis auto disponibile la Start Drive BVL Suceava: B1, B, BE, C, CE și D. Condiții de înscriere, informații complete și flotă modernă."
>
  <!-- Hero Banner -->
  <div class="relative w-full h-[350px] bg-[#111111] overflow-hidden flex flex-col justify-center items-center">
    <div class="absolute inset-0 bg-[url('/images/cat-b.png')] bg-cover bg-center opacity-30"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#111111]/60 to-[#111111]"></div>
    
    <div class="relative z-10 text-center flex flex-col items-center reveal">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-wide mb-6 uppercase">Categoriile Noastre</h1>
      <div class="flex items-center gap-2 text-white font-bold text-sm tracking-widest uppercase">
        <a href="/" class="hover:text-[#cc0000] transition-colors">Acasă</a>
        <span class="text-white">&gt;</span>
        <span class="text-[#cc0000]">Categorii</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-16 space-y-24">
    {categories.map((cat, index) => (
      <div class="flex flex-col reveal" style={`transition-delay: ${index * 100}ms`}>
        <div class="grid lg:grid-cols-2 gap-10 items-start mb-8">
          <a href={`/categoria/${cat.slug}`} class="block rounded-2xl overflow-hidden shadow-lg h-48 sm:h-64 lg:h-96 w-full group">
            <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </a>
          
          <div class="flex flex-col">
            <span class="text-sm text-[#cc0000] uppercase tracking-widest mb-1 font-bold">START DRIVE BVL</span>
            <a href={`/categoria/${cat.slug}`} class="hover:text-[#cc0000] transition-colors">
              <h2 class="text-4xl font-bold text-[#111111] mb-6">{cat.name}</h2>
            </a>
            
            <div class="space-y-4 mb-8">
              {cat.desc.map(d => (
                <p class="text-slate-600 font-light leading-relaxed">{d}</p>
              ))}
            </div>
            
            <h3 class="text-lg text-[#111111] font-bold mb-4">Condiții de înscriere:</h3>
            
            <ul class="space-y-3 mb-6">
              {cat.conditions.map(cond => (
                <li class="flex items-center gap-3 text-slate-600 font-light text-sm md:text-base">
                  <div class="w-5 h-5 rounded-full bg-[#cc0000] text-white flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  {cond}
                </li>
              ))}
            </ul>

            <div class="mt-4">
              <a href={`/categoria/${cat.slug}`} class="inline-flex items-center gap-2 bg-[#cc0000] hover:bg-red-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg active:scale-[0.98] uppercase tracking-wider text-xs">
                Detalii Curs & Înscriere
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>
        </div>

        {cat.info && (
          <div class="bg-red-50 border border-red-100 rounded-xl p-6 flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#cc0000]/10 text-[#cc0000] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <p class="text-slate-700 font-medium text-sm md:text-base leading-relaxed">
              {cat.info}
            </p>
          </div>
        )}
      </div>
    ))}
  </div>
</MainLayout>
