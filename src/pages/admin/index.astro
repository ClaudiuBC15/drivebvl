---
import MainLayout from '../../layouts/main.astro';
import { requireAuth } from '../../lib/auth';
import { getDB, queryOne, queryAll } from '../../lib/db';
import AdminLayout from '../../components/admin/AdminLayout';

export const prerender = false;

const redirect = requireAuth(Astro.request);
if (redirect) {
  return redirect;
}

const db = getDB(Astro.locals);

// 1. Fetch stats counts from DB (NO DEMO SEEDING DATA)
let todayLeadsCount = 0;
let totalLeads = 0;
let enrollLeadsCount = 0;
let contactLeadsCount = 0;
let phoneLeadsCount = 0;
let totalFaqs = 0;
let recentLeads: any[] = [];

let catStats = { B: 0, A: 0, C: 0, CE: 0, D: 0, others: 0, total: 0 };
let sourceStats = { web: 0, contact: 0, cat: 0, blog: 0, others: 0, total: 0 };

try {
  const todayCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM leads WHERE date(created_at) = date('now')");
  todayLeadsCount = todayCount?.total || 0;

  const totalCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM leads");
  totalLeads = totalCount?.total || 0;

  const enrollCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM leads WHERE source = 'website'");
  enrollLeadsCount = enrollCount?.total || 0;

  const contactCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM leads WHERE source = 'website_contact_page'");
  contactLeadsCount = contactCount?.total || 0;

  const phoneCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM leads WHERE source = 'phone'");
  phoneLeadsCount = phoneCount?.total || 0;

  const faqsCount = await queryOne<{ total: number }>(db, "SELECT COUNT(*) as total FROM faqs");
  totalFaqs = faqsCount?.total || 0;

  recentLeads = await queryAll<any>(db, 'SELECT * FROM leads ORDER BY created_at DESC LIMIT 5');

  // Categories distribution stats
  const categoryCounts = await queryAll<{ category: string; count: number }>(db, 'SELECT category, COUNT(*) as count FROM leads GROUP BY category');
  for (const row of categoryCounts) {
    const cat = (row.category || '').toUpperCase();
    const cnt = row.count || 0;
    catStats.total += cnt;
    if (cat === 'B') catStats.B += cnt;
    else if (cat === 'A') catStats.A += cnt;
    else if (cat === 'C') catStats.C += cnt;
    else if (cat === 'CE') catStats.CE += cnt;
    else if (cat === 'D') catStats.D += cnt;
    else catStats.others += cnt;
  }

  // Sources distribution stats
  const sourceCounts = await queryAll<{ source: string; count: number }>(db, 'SELECT source, COUNT(*) as count FROM leads GROUP BY source');
  for (const row of sourceCounts) {
    const s = row.source || '';
    const cnt = row.count || 0;
    sourceStats.total += cnt;
    if (s === 'website') sourceStats.web += cnt;
    else if (s === 'website_contact_page') sourceStats.contact += cnt;
    else if (s === 'website_category_page') sourceStats.cat += cnt;
    else if (s === 'blog') sourceStats.blog += cnt;
    else sourceStats.others += cnt;
  }
} catch (err) {
  console.error('Error querying dashboard DB stats:', err);
}

// 2. Line Chart Data (last 30 days)
let dailyLeads: { label: string; count: number }[] = [];
let linePath = '';
let areaPath = '';
let maxCount = 1;
try {
  const dailyLeadsQuery = await queryAll<{ day: string; count: number }>(db, `
    SELECT date(created_at) as day, COUNT(*) as count 
    FROM leads 
    WHERE created_at >= date('now', '-30 days')
    GROUP BY day 
    ORDER BY day ASC
  `);
  
  for (let i = 29; i >= 0; i--) {
    const d = new Date();
    d.setDate(d.getDate() - i);
    const dayStr = d.toISOString().substring(0, 10);
    const label = d.toLocaleDateString('ro-RO', { day: '2-digit', month: 'short' });
    const match = dailyLeadsQuery.find(r => r.day === dayStr);
    dailyLeads.push({
      label,
      count: match ? match.count : 0
    });
  }
  maxCount = Math.max(...dailyLeads.map(d => d.count), 1);
  const linePoints = dailyLeads.map((d, idx) => {
    const x = idx * (500 / 29);
    const y = 160 - (d.count / maxCount) * 120;
    return { x, y };
  });
  linePath = linePoints.map((p, idx) => `${idx === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
  areaPath = `${linePath} L 500 160 L 0 160 Z`;
} catch (err) {
  console.error('Error fetching line chart stats:', err);
}

// 3. Bar Chart Data (leads per hour)
const hourlyIntervals = ['08:00', '10:00', '12:00', '14:00', '16:00', '18:00', '20:00'];
let barPoints: any[] = [];
try {
  const hourlyLeadsQuery = await queryAll<{ hour: string; count: number }>(db, `
    SELECT strftime('%H', created_at) as hour, COUNT(*) as count 
    FROM leads 
    WHERE created_at >= date('now', '-30 days')
    GROUP BY hour
  `);
  
  const hourlyData = hourlyIntervals.map(interval => {
    const startHour = parseInt(interval.substring(0, 2));
    const h1 = String(startHour - 1).padStart(2, '0');
    const h2 = String(startHour).padStart(2, '0');
    const match1 = hourlyLeadsQuery.find(r => r.hour === h1);
    const match2 = hourlyLeadsQuery.find(r => r.hour === h2);
    return {
      label: interval,
      count: (match1 ? match1.count : 0) + (match2 ? match2.count : 0)
    };
  });
  
  const maxHourCount = Math.max(...hourlyData.map(h => h.count), 1);
  barPoints = hourlyData.map((h, idx) => {
    const width = 24;
    const x = idx * 64 + 28;
    const height = maxHourCount > 0 && h.count > 0 ? (h.count / maxHourCount) * 110 : 0;
    const y = 130 - height;
    return { x, y, width, height, label: h.label };
  });
} catch (err) {
  console.error('Error fetching bar chart stats:', err);
}

// Donut calculation helper functions
const totalCircum = 2 * Math.PI * 55; // ~345.575
const getDonutSegments = (stats: any) => {
  const tot = stats.total || 1;
  const segments = Object.keys(stats)
    .filter(k => k !== 'total')
    .map(key => ({
      key,
      val: stats[key],
      pct: stats[key] > 0 ? (stats[key] / tot) * 100 : 0
    }));
  
  let currentOffset = 0;
  return segments.map(seg => {
    const length = (seg.pct / 100) * totalCircum;
    const offset = currentOffset;
    currentOffset -= length;
    return {
      ...seg,
      length,
      offset
    };
  });
};

const catSegments = getDonutSegments(catStats);
const sourceSegments = getDonutSegments(sourceStats);

// Date formatting helper
function formatDate(dateStr: string) {
  if (!dateStr) return '';
  try {
    const cleanStr = dateStr.includes(' ') && !dateStr.includes('T') ? dateStr.replace(' ', 'T') : dateStr;
    const date = new Date(cleanStr);
    if (isNaN(date.getTime())) return dateStr;
    return date.toLocaleDateString('ro-RO', { 
      day: '2-digit', 
      month: 'short', 
      hour: '2-digit', 
      minute: '2-digit' 
    });
  } catch {
    return dateStr;
  }
}
