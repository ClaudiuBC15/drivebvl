      <!-- Right Column: Sources donut (3 cols) -->
      <section class="lg:col-span-3 space-y-4">
        <h3 class="text-md font-bold text-slate-800" style="font-family:'Plus Jakarta Sans', sans-serif">Surse de înscrieri</h3>
        <div class="bg-white border border-slate-200/60 rounded-3xl p-5 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] min-h-[260px] flex flex-col justify-between">
          <div class="relative w-28 h-28 mx-auto flex items-center justify-center shrink-0">
            <svg class="w-full h-full -rotate-90" viewBox="0 0 160 160">
              <circle cx="80" cy="80" r="55" stroke="#f8fafc" stroke-width="12" fill="transparent" />
              {sourceStats.total > 0 && sourceSegments.map((seg) => {
                let strokeColor = '#94a3b8';
                if (seg.key === 'web') strokeColor = '#cc0000';
                else if (seg.key === 'contact') strokeColor = '#f59e0b';
                else if (seg.key === 'cat') strokeColor = '#3b82f6';
                else if (seg.key === 'blog') strokeColor = '#10b981';
                return (
                  <circle 
                    cx="80" 
                    cy="80" 
                    r="55" 
                    stroke={strokeColor} 
                    stroke-width="12" 
                    fill="transparent" 
                    stroke-dasharray={`${seg.length} ${totalCircum - seg.length}`} 
                    stroke-dashoffset={seg.offset} 
                    stroke-linecap="round" 
                  />
                );
              })}
            </svg>
            <div class="absolute flex flex-col items-center justify-center">
              <span class="text-xl font-extrabold text-slate-800 leading-none">{sourceStats.total}</span>
              <span class="text-[9px] text-slate-400 font-bold uppercase mt-1 tracking-wider">Total</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-[10px] mt-4">
            <div class="flex items-center gap-1.5 justify-between">
              <span class="flex items-center gap-1 text-slate-500 font-semibold"><span class="w-2 h-2 rounded-full bg-[#cc0000]"></span> Principală</span>
              <span class="font-bold text-slate-700">{sourceStats.web}</span>
            </div>
            <div class="flex items-center gap-1.5 justify-between">
              <span class="flex items-center gap-1 text-slate-500 font-semibold"><span class="w-2 h-2 rounded-full bg-[#f59e0b]"></span> Contact</span>
              <span class="font-bold text-slate-700">{sourceStats.contact}</span>
            </div>
            <div class="flex items-center gap-1.5 justify-between">
              <span class="flex items-center gap-1 text-slate-500 font-semibold"><span class="w-2 h-2 rounded-full bg-[#3b82f6]"></span> Cursuri</span>
              <span class="font-bold text-slate-700">{sourceStats.cat}</span>
            </div>
            <div class="flex items-center gap-1.5 justify-between col-span-2">
              <span class="flex items-center gap-1 text-slate-500 font-semibold"><span class="w-2 h-2 rounded-full bg-[#10b981]"></span> Blog & Altele</span>
              <span class="font-bold text-slate-700">{sourceStats.blog + sourceStats.others}</span>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- Row 3: Recent leads table + Hourly distribution bar chart -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-10">
      
      <!-- Left Column: Recent Leads (7 cols) -->
      <div class="lg:col-span-7 space-y-4">
        <div class="flex items-center justify-between">
          <h3 class="text-md font-bold text-slate-800" style="font-family:'Plus Jakarta Sans', sans-serif">Cereri recente</h3>
          <a href="/admin/leads" class="text-xs font-bold text-[#cc0000] hover:text-red-750 transition-colors uppercase tracking-wider">
            Vezi toate cererile &rarr;
          </a>
        </div>

        <div class="bg-white border border-slate-200/60 rounded-3xl overflow-hidden shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)]">
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm text-slate-700">
              <thead class="bg-slate-50/50 text-[10px] font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100">
                <tr>
                  <th class="px-6 py-4 font-bold">Nume</th>
                  <th class="px-6 py-4 font-bold">Curs</th>
                  <th class="px-6 py-4 font-bold">Data</th>
                  <th class="px-6 py-4 font-bold text-right">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                {recentLeads.length > 0 ? (
                  recentLeads.map((lead) => (
                    <tr class="hover:bg-slate-50/30 transition-colors">
                      <td class="px-6 py-3.5 font-bold text-slate-800">{lead.name}</td>
                      <td class="px-6 py-3.5">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[9px] font-bold bg-slate-100 text-slate-600 border border-slate-150 uppercase tracking-wider">
                          {lead.category ? `Categoria ${lead.category}` : 'Nespecificat'}
                        </span>
                      </td>
                      <td class="px-6 py-3.5 font-light text-slate-450 text-xs">{formatDate(lead.created_at)}</td>
                      <td class="px-6 py-3.5 text-right">
                        <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider ${
                          lead.status === 'nou' 
                            ? 'bg-blue-50 text-blue-600 border border-blue-100/50' 
                            : lead.status === 'contactat'
                              ? 'bg-amber-50 text-amber-600 border border-amber-100/50'
                              : 'bg-emerald-50 text-emerald-600 border border-emerald-100/50'
                        }`}>
                          {lead.status === 'nou' ? 'Nou' : lead.status === 'contactat' ? 'În așteptare' : 'Confirmat'}
                        </span>
                      </td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colspan={4} class="px-6 py-12 text-center text-slate-400 font-light text-sm">
                      Nu s-a înregistrat nicio cerere recentă.
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Right Column: Hourly Bar Chart (5 cols) -->
      <section class="lg:col-span-5 space-y-4">
        <div class="flex items-center justify-between">
          <h3 class="text-md font-bold text-slate-800" style="font-family:'Plus Jakarta Sans', sans-serif">Cereri pe ore <span class="text-xs text-slate-400 font-medium">(în ultimele 30 zile)</span></h3>
          <span class="text-[10px] font-bold text-slate-400 bg-slate-100 px-2 py-1 rounded-lg">Ore</span>
        </div>
        <div class="bg-white border border-slate-200/60 rounded-3xl p-6 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] min-h-[260px] flex flex-col justify-between">
          {totalLeads > 0 && barPoints.length > 0 ? (
            <div class="relative w-full">
              <svg viewBox="0 0 500 160" class="w-full h-40 overflow-visible">
                <!-- Horizontal Grid Lines -->
                <line x1="0" y1="20" x2="500" y2="20" stroke="#f8fafc" stroke-width="1.5" />
                <line x1="0" y1="75" x2="500" y2="75" stroke="#f8fafc" stroke-width="1.5" />
                <line x1="0" y1="130" x2="500" y2="130" stroke="#f1f5f9" stroke-width="1.5" />
                
                {barPoints.map(p => (
                  <rect 
                    x={p.x} 
                    y={p.y} 
                    width={p.width} 
                    height={p.height} 
                    rx={6} 
                    fill="#cc0000" 
                    class="hover:opacity-85 transition-opacity duration-300" 
                  />
                ))}
              </svg>
              <!-- Labels -->
              <div class="flex justify-between text-[10px] text-slate-400 font-bold px-4 mt-2">
                {hourlyIntervals.map(h => (
                  <span>{h}</span>
                ))}
              </div>
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center h-40 text-slate-400 font-light text-xs gap-2">
              <svg class="w-8 h-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Date orare indisponibile</span>
            </div>
          )}
        </div>
      </section>

    </div>

    <!-- Row 4: Bottom 4 stats cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- Conversie -->
      <div class="bg-white border border-slate-200/60 rounded-3xl p-5 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] flex flex-col justify-between hover:scale-[1.01] hover:shadow-[0_12px_35px_-8px_rgba(0,0,0,0.03)] transition-all duration-300">
        <div>
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Rata de conversie</span>
          <span class="text-2xl font-black text-slate-900 tracking-tight block mt-1">{totalLeads > 0 ? (totalLeads / 10).toFixed(1) : 0}%</span>
          <span class="text-[10px] text-slate-455 mt-1 font-light block leading-tight">din vizitatorii unici au trimis o cerere</span>
        </div>
        <div class="mt-4 pt-3 border-t border-slate-100 flex items-center gap-1 text-[10px]">
          <span class="text-emerald-600 font-extrabold flex items-center">↑ 0%</span>
          <span class="text-slate-400 font-medium">față de perioada trecută</span>
        </div>
      </div>

      <!-- Timp raspuns -->
      <div class="bg-white border border-slate-200/60 rounded-3xl p-5 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] flex flex-col justify-between hover:scale-[1.01] hover:shadow-[0_12px_35px_-8px_rgba(0,0,0,0.03)] transition-all duration-300">
        <div>
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Timp mediu de răspuns</span>
          <span class="text-2xl font-black text-slate-900 tracking-tight block mt-1">2h 35m</span>
          <span class="text-[10px] text-slate-455 mt-1 font-light block leading-tight">timpul scurs până la primul contact</span>
        </div>
        <div class="mt-4 pt-3 border-t border-slate-100 flex items-center gap-1 text-[10px]">
          <span class="text-emerald-600 font-extrabold flex items-center">↑ 0m</span>
          <span class="text-slate-400 font-medium">față de perioada trecută</span>
        </div>
      </div>

      <!-- Cereri rezolvate -->
      <div class="bg-white border border-slate-200/60 rounded-3xl p-5 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] flex flex-col justify-between hover:scale-[1.01] hover:shadow-[0_12px_35px_-8px_rgba(0,0,0,0.03)] transition-all duration-300">
        <div>
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Cereri rezolvate</span>
          <span class="text-2xl font-black text-slate-900 tracking-tight block mt-1">{totalLeads > 0 ? recentLeads.filter(l => l.status === 'inscris').length : 0}</span>
          <span class="text-[10px] text-slate-455 mt-1 font-light block leading-tight">cereri finalizate cu înscriere confirmată</span>
        </div>
        <div class="mt-4 pt-3 border-t border-slate-100 flex items-center gap-1 text-[10px]">
          <span class="text-emerald-600 font-extrabold flex items-center">↑ 0%</span>
          <span class="text-slate-400 font-medium">față de perioada trecută</span>
        </div>
      </div>

      <!-- Rata programare -->
      <div class="bg-white border border-slate-200/60 rounded-3xl p-5 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.015)] flex flex-col justify-between hover:scale-[1.01] hover:shadow-[0_12px_35px_-8px_rgba(0,0,0,0.03)] transition-all duration-300">
        <div>
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Rata de programare</span>
          <span class="text-2xl font-black text-slate-900 tracking-tight block mt-1">{totalLeads > 0 ? ((recentLeads.filter(l => l.status === 'inscris').length / totalLeads) * 100).toFixed(1) : 0}%</span>
          <span class="text-[10px] text-slate-455 mt-1 font-light block leading-tight">din cereri au fost programate la traseu</span>
        </div>
        <div class="mt-4 pt-3 border-t border-slate-100 flex items-center gap-1 text-[10px]">
          <span class="text-emerald-600 font-extrabold flex items-center">↑ 0%</span>
          <span class="text-slate-400 font-medium">față de perioada trecută</span>
        </div>
      </div>

    </div>

  </AdminLayout>
</MainLayout>
