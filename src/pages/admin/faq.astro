---
import MainLayout from '../../layouts/main.astro';
import { requireAuth } from '../../lib/auth';
import { getDB, queryAll } from '../../lib/db';
import AdminLayout from '../../components/admin/AdminLayout';
import FaqManager from '../../components/admin/FaqManager';

export const prerender = false;

const redirect = requireAuth(Astro.request);
if (redirect) {
  return redirect;
}

const db = getDB(Astro.locals);
let faqs: any[] = [];

try {
  faqs = await queryAll(db, 'SELECT * FROM faqs ORDER BY category, sort_order ASC');
} catch (err) {
  console.error('Error fetching FAQs:', err);
}
---

<MainLayout title="FAQ CMS | Start Drive BVL" description="Administrare întrebări frecvente.">
  <AdminLayout activeTab="faq" client:load>
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h3 class="text-xl font-bold text-slate-800">Întrebări Frecvente (FAQ)</h3>
        <p class="text-xs text-slate-500 font-light mt-1">Creează, editează sau șterge întrebări FAQ optimizate pentru Featured Snippets și Answer Engines.</p>
      </div>
    </div>
    
    <FaqManager initialFaqs={faqs} client:load />
  </AdminLayout>
</MainLayout>
