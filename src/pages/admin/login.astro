---
import MainLayout from '../../layouts/main.astro';
import { isAuthenticated } from '../../lib/auth';

export const prerender = false;

// If already logged in, redirect to admin index
if (isAuthenticated(Astro.request)) {
  return Astro.redirect('/admin');
}
---

<MainLayout title="Autentificare Admin | Start Drive BVL" description="Autentificare securizată în panoul de administrare Start Drive BVL.">
  <div class="min-h-screen bg-[#fafafa] flex flex-col justify-between items-center pt-28 md:pt-32 pb-6 relative overflow-hidden font-sans">
    
    <!-- Top centered login form area -->
    <div class="w-full max-w-md px-6 text-center z-10 flex-1 flex flex-col justify-center">
      
      <!-- Brand Logo -->
      <div class="mb-6">
        <img 
          src="/images/logo.png" 
          alt="Start Drive BVL Logo" 
          class="h-24 mx-auto object-contain"
        />
      </div>

      <!-- Title & Greeting -->
      <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Autentificare</h1>
        <p class="text-slate-500 font-light text-sm mt-2 max-w-xs mx-auto leading-relaxed">
          Bine ai revenit! Te rugăm să te autentifici pentru a continua.
        </p>
      </div>

      <!-- Card container -->
      <div class="bg-white border border-slate-200/60 rounded-3xl p-8 md:p-10 shadow-[0_10px_35px_-5px_rgba(0,0,0,0.03)] text-left relative">
        <form id="login-form" class="space-y-6">
          
          <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-600 text-xs font-semibold p-4 rounded-xl"></div>

          <!-- Email / Username input -->
          <div>
            <label for="username" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Email</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <input
                type="text"
                id="username"
                name="username"
                required
                class="w-full bg-white border border-slate-200 rounded-xl pl-12 pr-4 py-3.5 text-slate-800 placeholder-slate-400 focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-sm"
                placeholder="admin@bvl.ro"
              />
            </div>
          </div>

          <!-- Password input -->
          <div>
            <label for="password" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Parolă</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2a3 3 0 01-3 3H6a3 3 0 01-3-3v-6a3 3 0 013-3h2m2 2V6a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full bg-white border border-slate-200 rounded-xl pl-12 pr-12 py-3.5 text-slate-800 placeholder-slate-400 focus:border-[#cc0000] focus:ring-4 focus:ring-red-500/10 transition-all outline-none text-sm"
                placeholder="••••••••••"
              />
              <!-- Password toggle show/hide -->
              <button
                type="button"
                id="toggle-password"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-650 focus:outline-none cursor-pointer"
              >
                <!-- Eye icon (show) -->
                <svg id="eye-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <!-- Eye-off icon (hide) -->
                <svg id="eye-off-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Remember me & Forgot Password -->
          <div class="flex items-center justify-between text-xs">
            <div class="flex items-center gap-2">
              <input
                type="checkbox"
                id="remember"
                name="remember"
                class="h-4 w-4 rounded border-slate-300 text-[#cc0000] focus:ring-[#cc0000] cursor-pointer"
              />
              <label for="remember" class="text-slate-500 select-none cursor-pointer">Ține-mă minte</label>
            </div>
            <a href="#" id="forgot-password-link" class="text-[#cc0000] hover:text-red-700 font-semibold transition-colors">
              Ai uitat parola?
            </a>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-[#cc0000] hover:bg-red-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-red-500/20 active:scale-[0.99] flex items-center justify-center gap-2 cursor-pointer select-none uppercase tracking-wider text-xs"
          >
            Autentifică-te
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h3a3 3 0 013 3v1" />
            </svg>
          </button>



        </form>
      </div>

      <!-- Back link -->
      <div class="text-center mt-6">
        <a href="/" class="text-xs text-slate-500 hover:text-slate-700 transition-colors uppercase tracking-wider font-semibold">
          &larr; Înapoi pe site
        </a>
      </div>

    </div>



    <!-- Copyright Footer -->
    <footer class="text-center text-[11px] text-slate-400 font-light mt-4 w-full z-10 py-2">
      © 2025 Start Drive BVL. Toate drepturile rezervate.
    </footer>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('login-form');
      const errorMsg = document.getElementById('error-message');
      const submitBtn = document.getElementById('submit-btn');
      
      const passwordInput = document.getElementById('password');
      const togglePasswordBtn = document.getElementById('toggle-password');
      const eyeIcon = document.getElementById('eye-icon');
      const eyeOffIcon = document.getElementById('eye-off-icon');

      const forgotPasswordLink = document.getElementById('forgot-password-link');

      // 1. Password show/hide toggle logic
      if (passwordInput && togglePasswordBtn && eyeIcon && eyeOffIcon) {
        togglePasswordBtn.addEventListener('click', () => {
          if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            eyeIcon.classList.add('hidden');
            eyeOffIcon.classList.remove('hidden');
          } else {
            passwordInput.type = 'password';
            eyeIcon.classList.remove('hidden');
            eyeOffIcon.classList.add('hidden');
          }
        });
      }

      // 2. Alert notifications for unimplemented mock buttons
      if (forgotPasswordLink) {
        forgotPasswordLink.addEventListener('click', (e) => {
          e.preventDefault();
          alert('Pentru resetarea parolei de administrator, vă rugăm să contactați furnizorul de servicii IT.');
        });
      }


      // 3. Form login submission
      if (form && errorMsg && submitBtn) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorMsg.classList.add('hidden');
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<div class="w-4 h-4 rounded-full border-2 border-white border-t-transparent animate-spin"></div> Autentificare...';

          const formData = new FormData(form);
          const username = formData.get('username');
          const password = formData.get('password');

          try {
            const res = await fetch('/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ username, password })
            });

            const data = await res.json();

            if (res.ok && data.success) {
              window.location.href = '/admin';
            } else {
              errorMsg.textContent = data.error || 'Autentificare eșuată';
              errorMsg.classList.remove('hidden');
              submitBtn.disabled = false;
              submitBtn.innerHTML = 'Autentifică-te <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h3a3 3 0 013 3v1" /></svg>';
            }
          } catch (err) {
            errorMsg.textContent = 'A apărut o eroare la conectare. Încearcă din nou.';
            errorMsg.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Autentifică-te <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h3a3 3 0 013 3v1" /></svg>';
          }
        });
      }
    });
  </script>
</MainLayout>
