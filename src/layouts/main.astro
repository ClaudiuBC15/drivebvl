      "@type": "DrivingSchool",
      "name": "Start Drive BVL",
      "image": "/images/logo.png",
      "url": "https://startdrivebvl.ro/",
      "telephone": "+40744420905",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Strada Mărășești 48",
        "addressLocality": "Suceava",
        "addressRegion": "SV",
        "postalCode": "720166",
        "addressCountry": "RO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.6416,
        "longitude": 26.2575
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "17:00"
      },
      "priceRange": "$$"
    }
    </script>
  </head>
  <body class="antialiased bg-white">
