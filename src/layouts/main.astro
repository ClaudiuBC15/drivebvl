---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import { getDB, queryAll } from '../lib/db';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage,
  canonical,
} = Astro.props;

const db = getDB(Astro.locals);
let dbSettings = {};

try {
  const rows = await queryAll<any>(db, 'SELECT key, value FROM settings');
  rows.forEach(r => {
    (dbSettings as any)[r.key] = r.value;
  });
} catch (err) {
  console.error('Error fetching settings for main layout SEO:', err);
}

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const isBlog = Astro.url.pathname === '/blog' || Astro.url.pathname === '/blog/';

let dbTitle = null;
let dbDescription = null;
let dbOgImage = null;
let dbKeywords = null;

if (isHome) {
  dbTitle = (dbSettings as any).seo_home_title;
  dbDescription = (dbSettings as any).seo_home_description;
  dbOgImage = (dbSettings as any).seo_home_image;
  dbKeywords = (dbSettings as any).seo_home_keywords;
} else if (isBlog) {
  dbTitle = (dbSettings as any).seo_blog_title;
  dbDescription = (dbSettings as any).seo_blog_description;
  dbOgImage = (dbSettings as any).seo_blog_image;
  dbKeywords = (dbSettings as any).seo_blog_keywords;
}

const finalTitle = title || dbTitle || "Start Drive BVL | Școala de Șoferi Suceava";
const finalDescription = description || dbDescription || "Obține-ți permisul auto cu încredere alături de Start Drive BVL Suceava. Instructori experimentați, flotă modernă și rată mare de promovabilitate.";
const finalOgImage = ogImage || dbOgImage || "/images/logo.png";
const finalKeywords = dbKeywords || "permis auto, scoala de soferi suceava, cat B, CPI, CPC";

const siteUrl = 'https://startdrivebvl.ro';
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = finalOgImage.startsWith('http') ? finalOgImage : `${siteUrl}${finalOgImage}`;
---

<!DOCTYPE html>
<html lang="ro" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={finalDescription} />
    <meta name="keywords" content={finalKeywords} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{finalTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Start Drive BVL" />
    <meta property="og:locale" content="ro_RO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- CookieYes -->
    <script is:inline id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/b4a49c69d0d36c5b96796c05/script.js"></script>

    <!-- Fonts: Plus Jakarta Sans (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">

    <!-- SEO / GEO / AEO JSON-LD -->
