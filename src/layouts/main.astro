---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Start Drive BVL | Școala de Șoferi Suceava" } = Astro.props;
---

<!DOCTYPE html>
<html lang="ro" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Obține-ți permisul auto cu încredere alături de Start Drive BVL Suceava." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="https://i.imgur.com/pzRXduP.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- CookieYes script (Placeholder client_data ID - necesită înlocuire cu codul tău real din contul CookieYes) -->
    <script is:inline id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/b4a49c69d0d36c5b96796c05/script.js"></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;700&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- SEO / GEO / AEO JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "AutoSchool",
      "name": "Start Drive BVL",
      "image": "https://i.imgur.com/pzRXduP.png",
      "url": "https://startdrivebvl.ro/",
      "telephone": "0744420905",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Strada Mărășești 48",
        "addressLocality": "Suceava",
        "addressRegion": "SV",
        "postalCode": "720166",
        "addressCountry": "RO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.6416,
        "longitude": 26.2575
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday"
        ],
        "opens": "08:00",
        "closes": "17:00"
      },
      "priceRange": "$$"
    }
    </script>
  </head>
  <body class="font-sans antialiased text-slate-800 bg-white selection:bg-rose-100 selection:text-rose-900" style="font-family: 'Montserrat', sans-serif;">
    <!-- Navbar -->
    <header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm transition-all duration-300">
      <div class="w-full max-w-[1500px] mx-auto px-4 lg:px-8 h-24 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group relative z-[110]">
          <img src="/logo-nou.png" alt="Start Drive BVL" class="h-14 sm:h-16 md:h-20 object-contain group-hover:scale-105 transition-transform duration-300" />
        </a>
        
        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-4 xl:gap-8 text-[#121113] whitespace-nowrap" style="font-family: 'Lexend', sans-serif; font-size: 13px; text-transform: uppercase; font-weight: 700; letter-spacing: -0.2px;">
          <a href="/" class="hover:text-[#cc0000] transition-colors">ACASĂ</a>
          <a href="/instructori" class="hover:text-[#cc0000] transition-colors">INSTRUCTORI</a>
          <a href="/categorii" class="hover:text-[#cc0000] transition-colors">CATEGORII</a>
          <a href="/intrebari-frecvente" class="hover:text-[#cc0000] transition-colors">ÎNTREBĂRI FRECVENTE</a>
          <a href="/galerie" class="hover:text-[#cc0000] transition-colors">GALERIE</a>
          <a href="/articole" class="hover:text-[#cc0000] transition-colors">ARTICOLE</a>
          <a href="/inscrieri" class="hover:text-[#cc0000] transition-colors">ÎNSCRIERI</a>
        </nav>

        <!-- Desktop Right (Contact + Phone) -->
        <div class="hidden lg:flex items-center gap-6 shrink-0 relative z-[110]">
          <a href="/contact" class="bg-[#cc0000] hover:bg-[#a30000] text-white font-bold py-3 px-8 rounded transition-colors text-sm uppercase tracking-wider shadow-md whitespace-nowrap">
            CONTACT
          </a>
          <div class="flex items-center gap-3 border-l-2 border-slate-100 pl-6 whitespace-nowrap shrink-0">
            <div class="relative flex items-center justify-center w-11 h-11 rounded-full border-[2.5px] border-slate-800 shrink-0">
              <svg class="w-5 h-5 text-slate-800" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <div class="absolute -top-1.5 -right-1.5 bg-white border-[2.5px] border-slate-800 rounded-full w-5 h-5 flex items-center justify-center text-slate-800 text-[12px] font-bold">+</div>
            </div>
            <div class="flex flex-col">
              <span class="text-[11px] text-slate-500 font-bold uppercase tracking-wide">Sună acum</span>
              <a href="tel:0744420905" class="text-lg font-extrabold text-slate-900 hover:text-[#cc0000] transition-colors leading-none mt-0.5 tracking-tight">0744 420 905</a>
            </div>
          </div>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden relative z-[110] p-2 text-slate-800 hover:text-[#cc0000] focus:outline-none" aria-label="Toggle Menu">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>

      <!-- Mobile Slide-over Nav -->
      <div id="mobile-menu" class="fixed inset-0 bg-white z-[105] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex flex-col pt-28 px-6 pb-6 overflow-y-auto">
        <nav class="flex flex-col gap-6 text-lg" style="font-family: 'Lexend', sans-serif; text-transform: uppercase; font-weight: 700;">
          <a href="/" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">ACASĂ</a>
          <a href="/instructori" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">INSTRUCTORI</a>
          <a href="/categorii" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">CATEGORII</a>
          <a href="/intrebari-frecvente" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">ÎNTREBĂRI FRECVENTE</a>
          <a href="/galerie" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">GALERIE</a>
          <a href="/articole" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">ARTICOLE</a>
          <a href="/inscrieri" class="mobile-link text-slate-900 hover:text-[#cc0000] border-b border-slate-100 pb-2">ÎNSCRIERI</a>
        </nav>
        
        <div class="mt-auto pt-8 flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border-2 border-[#cc0000] flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cc0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">Sună pentru info</p>
              <a href="tel:0744420905" class="text-xl font-extrabold text-slate-900">0744 420 905</a>
            </div>
          </div>
          <a href="/contact" class="mobile-link w-full bg-[#cc0000] text-white text-center font-bold py-4 rounded uppercase tracking-widest text-sm shadow-md">
            CONTACT
          </a>
        </div>
      </div>
    </header>

    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Footer (Ovasal Style Compact) -->
    <footer class="bg-[#0f0f0f] relative overflow-hidden border-t-2 border-[#cc0000]">
      <!-- Background image fade -->
      <div class="absolute inset-y-0 left-0 w-1/2 lg:w-1/3 opacity-30 pointer-events-none">
        <div class="absolute inset-0 bg-[url('/footer-bg.jpg')] bg-cover bg-left"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#0f0f0f]/60 to-[#0f0f0f]"></div>
      </div>
      <div class="absolute inset-y-0 left-0 w-full bg-gradient-to-t from-[#0f0f0f] to-transparent opacity-80 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 pt-16 pb-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
          
          <!-- Column 1: Brand -->
          <div class="lg:col-span-2 space-y-5">
            <div class="mb-4">
              <div class="bg-white rounded-xl p-3 inline-block shadow-lg">
                <img src="/footer-logo.png" alt="Start Drive BVL Banner" class="w-full max-w-[280px] object-contain" />
              </div>
            </div>
            
            <div class="pt-2">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-white font-bold text-sm">Contact</span>
                <div class="h-[1px] w-12 bg-white/20"></div>
              </div>
              <a href="tel:0744420905" class="text-lg font-bold text-[#cc0000] hover:text-white transition-colors">0744 420 905</a>
            </div>

            <p class="text-xs text-slate-500 pt-6 max-w-xs">
              Copyrights &copy; {new Date().getFullYear()}. Website made by <span class="text-[#cc0000] font-bold">Start Drive BVL</span>.
            </p>
          </div>

          <!-- Column 2: Despre Noi -->
          <div>
            <h4 class="text-base font-bold text-white mb-6">Despre noi</h4>
            <ul class="space-y-3">
              <li><a href="/" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Despre noi</a></li>
              <li><a href="/instructori" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Echipa</a></li>
              <li><a href="/galerie" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Galerie Foto</a></li>
              <li><a href="/articole" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Articole</a></li>
            </ul>
          </div>

          <!-- Column 3: Categorii -->
          <div>
            <h4 class="text-base font-bold text-white mb-6">Categorii</h4>
            <ul class="space-y-3">
              <li><a href="/categorii" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Categoria B</a></li>
              <li><a href="/categorii" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Categoria B1 & BE</a></li>
              <li><a href="/categorii" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Categoria C & CE</a></li>
              <li><a href="/intrebari-frecvente" class="text-slate-400 text-sm hover:text-white transition-colors flex items-center gap-3"><span class="w-1 h-1 bg-slate-500 rounded-sm"></span> Întrebări Frecvente</a></li>
            </ul>
          </div>
        </div>

        <!-- Bottom Bar -->
        <div class="flex flex-wrap gap-8 text-xs text-slate-500 pt-8 border-t border-white/5 relative">
          <a href="#" class="hover:text-white transition-colors">Politica de confidențialitate</a>
          <a href="#" class="hover:text-white transition-colors">Termeni și condiții</a>
          <a href="https://anpc.ro/" target="_blank" class="hover:text-white transition-colors">ANPC</a>
          <a href="https://ec.europa.eu/consumers/odr" target="_blank" class="hover:text-white transition-colors">Sol EU</a>
          
          <!-- Back to top -->
          <button onclick="window.scrollTo({top:0, behavior:'smooth'})" class="absolute right-0 -top-8 md:-top-4 text-[#cc0000] font-bold uppercase tracking-widest text-[0.65rem] hover:text-white transition-colors group flex flex-col items-center gap-2">
            <span class="writing-vertical text-slate-400 group-hover:text-white transition-colors">Înapoi sus</span>
            <div class="w-1 h-8 bg-[#cc0000] group-hover:bg-white transition-colors"></div>
          </button>
        </div>
      </div>
    </footer>
    
    <style>
      .writing-vertical {
        writing-mode: vertical-rl;
        text-orientation: mixed;
      }
      @media (min-width: 768px) {
        .writing-vertical {
          writing-mode: horizontal-tb;
        }
      }
      
      /* Mobile Menu Active State */
      .no-scroll {
        overflow: hidden;
      }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIconPath = document.getElementById('menu-icon-path');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        let isMenuOpen = false;

        function toggleMenu() {
          isMenuOpen = !isMenuOpen;
          if(isMenuOpen) {
            mobileMenu.classList.remove('translate-x-full');
            document.body.classList.add('no-scroll');
            menuIconPath.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
          } else {
            mobileMenu.classList.add('translate-x-full');
            document.body.classList.remove('no-scroll');
            menuIconPath.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7'); // Hamburger icon
          }
        }

        if(mobileMenuBtn) {
          mobileMenuBtn.addEventListener('click', toggleMenu);
        }

        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            if(isMenuOpen) toggleMenu();
          });
        });
      });
    </script>
  </body>
</html>
